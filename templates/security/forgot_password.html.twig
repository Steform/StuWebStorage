{% extends 'base.html.twig' %}

{% set currentLocale = app.request.locale|default('en') %}

{% block title %}{{ 'security.password_reset.forgot.meta.title'|trans({}, 'messages', currentLocale) }}{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">{{ 'security.password_reset.forgot.title'|trans({}, 'messages', currentLocale) }}</h1>
                    <p class="text-muted">{{ 'security.password_reset.forgot.subtitle'|trans({}, 'messages', currentLocale) }}</p>

                    <form method="post" action="{{ path('app_password_forgot_submit') }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token(csrfForgot) }}">
                        <div class="mb-3">
                            <label for="forgot_email" class="form-label">{{ 'security.password_reset.forgot.email'|trans({}, 'messages', currentLocale) }}</label>
                            <input id="forgot_email" name="email" type="email" class="form-control" autocomplete="email" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 mb-2">{{ 'security.password_reset.forgot.submit'|trans({}, 'messages', currentLocale) }}</button>
                        <a class="btn btn-outline-secondary w-100" href="{{ path('app_login') }}">{{ 'security.password_reset.back_to_login'|trans({}, 'messages', currentLocale) }}</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
