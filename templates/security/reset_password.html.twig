{% extends 'base.html.twig' %}

{% set resetLocale = resetLocale|default(app.request.locale|default('en')) %}

{% block title %}{{ 'security.password_reset.reset.meta.title'|trans({}, 'messages', resetLocale) }}{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">{{ 'security.password_reset.reset.title'|trans({}, 'messages', resetLocale) }}</h1>
                    <p class="text-muted">{{ 'security.password_reset.reset.subtitle'|trans({}, 'messages', resetLocale) }}</p>

                    <form method="post" action="{{ path('app_password_reset_submit', {token: token}) }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token(csrfReset) }}">
                        <input type="hidden" name="lang" value="{{ resetLocale }}">
                        <div class="mb-3">
                            <label for="reset_password" class="form-label">{{ 'security.password_reset.reset.password'|trans({}, 'messages', resetLocale) }}</label>
                            <input id="reset_password" name="password" type="password" class="form-control" autocomplete="new-password" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 mb-2">{{ 'security.password_reset.reset.submit'|trans({}, 'messages', resetLocale) }}</button>
                        <a class="btn btn-outline-secondary w-100" href="{{ path('app_login', {lang: resetLocale}) }}">{{ 'security.password_reset.back_to_login'|trans({}, 'messages', resetLocale) }}</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
