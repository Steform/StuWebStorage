{% extends 'base.html.twig' %}

{% set currentLocale = app.request.locale|default('fr') %}
{% block title %}{{ 'security.login.meta.title'|trans({}, 'messages', currentLocale) }}{% endblock %}
{% block favicon %}
    <link rel="icon" type="{{ storage_favicon_type() }}" href="{{ asset(storage_favicon_href()) }}">
{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">{{ 'security.login.title'|trans({}, 'messages', currentLocale) }}</h1>
                    <p class="text-muted">{{ 'security.login.subtitle'|trans({}, 'messages', currentLocale) }}</p>

                    {% if error %}
                        <div class="alert alert-danger" role="alert">
                            {{ error.messageKey|trans(error.messageData, 'messages', currentLocale) }}
                        </div>
                    {% endif %}

                    <form method="post" action="{{ path('app_login_check') }}">
                        <div class="mb-3">
                            <label for="email" class="form-label">{{ 'security.login.email'|trans({}, 'messages', currentLocale) }}</label>
                            <input id="email" name="email" type="email" class="form-control" value="{{ last_username|default('') }}" placeholder="{{ 'security.login.email_placeholder'|trans({}, 'messages', currentLocale) }}" required>
                        </div>
                        <div class="mb-3">
                            <label for="password" class="form-label">{{ 'security.login.password'|trans({}, 'messages', currentLocale) }}</label>
                            <input id="password" name="password" type="password" class="form-control" placeholder="{{ 'security.login.password_placeholder'|trans({}, 'messages', currentLocale) }}" required>
                        </div>
                        <div class="form-check mb-3">
                            <input id="remember_me" name="_remember_me" type="checkbox" class="form-check-input" value="1">
                            <label for="remember_me" class="form-check-label">{{ 'security.login.remember_me'|trans({}, 'messages', currentLocale) }}</label>
                        </div>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        <button type="submit" class="btn btn-primary w-100">{{ 'security.login.submit'|trans({}, 'messages', currentLocale) }}</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
