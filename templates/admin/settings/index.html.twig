{% extends 'base.html.twig' %}
{% set currentLocale = app.request.locale|default('fr') %}

{% block title %}{{ 'admin.settings.meta.title'|trans({}, 'messages', currentLocale) }}{% endblock %}

{% block flash_messages %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('css/admin-settings.css') }}" rel="stylesheet">
{% endblock %}

{% block top_navigation %}
    {% include 'components/_storage_admin_nav.html.twig' %}
{% endblock %}

{% block main_container_class %}container-fluid admin-settings py-4{% endblock %}

{% block body %}
    <header class="admin-settings__header mb-4">
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
            <div>
                <p class="admin-settings__eyebrow text-uppercase mb-2">{{ 'admin.settings.page.eyebrow'|trans({}, 'messages', currentLocale) }}</p>
                <h1 class="h3 mb-2">{{ 'admin.settings.page.title'|trans({}, 'messages', currentLocale) }}</h1>
                <p class="text-body-secondary mb-0">{{ 'admin.settings.page.subtitle'|trans({}, 'messages', currentLocale) }}</p>
            </div>
            <div class="admin-settings__status-strip d-flex flex-wrap gap-2">
                <span class="admin-settings__status-pill {% if accessGateSettings.maintenanceModeEnabled %}admin-settings__status-pill--warning{% else %}admin-settings__status-pill--ok{% endif %}">
                    <i class="bi bi-tools" aria-hidden="true"></i>
                    {% if accessGateSettings.maintenanceModeEnabled %}
                        {{ 'admin.settings.maintenance.status_active'|trans({}, 'messages', currentLocale) }}
                    {% else %}
                        {{ 'admin.settings.maintenance.status_inactive'|trans({}, 'messages', currentLocale) }}
                    {% endif %}
                </span>
                <span class="admin-settings__status-pill admin-settings__status-pill--info">
                    <i class="bi bi-shield-check" aria-hidden="true"></i>
                    {{ 'admin.settings.summary.antibot_gate'|trans({}, 'messages', currentLocale) }}
                </span>
            </div>
        </div>
    </header>

    {% include 'components/_flash_messages.html.twig' %}

    <div class="row g-4">
        <div class="col-12 col-xl-8">
            <div class="row g-4">
                <div class="col-12">
                    {% include 'admin/settings/_maintenance_card.html.twig' %}
                </div>
                <div class="col-12">
                    {% include 'admin/settings/_antibot_card.html.twig' %}
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="admin-settings__sidebar d-grid gap-4">
                <div class="card border-0 shadow-sm admin-settings__metric-card">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <span class="admin-settings__metric-icon admin-settings__metric-icon--quota" aria-hidden="true">
                                <i class="bi bi-hdd-stack-fill"></i>
                            </span>
                            <div>
                                <h2 class="h6 mb-1">{{ 'admin.settings.summary.default_quota'|trans({}, 'messages', currentLocale) }}</h2>
                                <p class="text-body-secondary small mb-0">{{ 'admin.settings.summary.default_quota_help'|trans({}, 'messages', currentLocale) }}</p>
                            </div>
                        </div>
                        <div class="admin-settings__metric-value">
                            {% if defaultQuotaBytes > 0 %}
                                {{ defaultQuotaBytes|files_size_format }}
                            {% else %}
                                {{ 'storage.home.stat_space_unlimited'|trans({}, 'messages', currentLocale) }}
                            {% endif %}
                        </div>
                        <a class="btn btn-outline-primary btn-sm mt-3" href="{{ path('admin_users_index') }}">
                            {{ 'admin.settings.storage.manage_users'|trans({}, 'messages', currentLocale) }}
                        </a>
                    </div>
                </div>

                {% include 'admin/settings/_server_disk_card.html.twig' %}
            </div>
        </div>
    </div>
{% endblock %}
