{% extends 'base.html.twig' %}
{% set currentLocale = app.request.locale|default('fr') %}

{% block title %}{{ 'admin.bug_reports.meta.title'|trans({}, 'messages', currentLocale) }}{% endblock %}

{% block flash_messages %}{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('css/admin-bug-reports.css') }}" rel="stylesheet">
{% endblock %}

{% block top_navigation %}
    {% include 'components/_storage_admin_nav.html.twig' %}
{% endblock %}

{% block main_container_class %}container-fluid px-3 px-lg-4 py-4{% endblock %}

{% block body %}
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                <h1 class="h4 mb-0">{{ 'admin.bug_reports.list.title'|trans({}, 'messages', currentLocale) }}</h1>
            </div>

            <form class="row g-2 mb-3" method="get" action="{{ path('admin_bug_reports_index') }}">
                <div class="col-12 col-md-2">
                    <select class="form-select" name="status">
                        <option value="">{{ 'admin.bug_reports.filters.status_all'|trans({}, 'messages', currentLocale) }}</option>
                        <option value="new" {% if statusFilter == 'new' %}selected{% endif %}>{{ 'bug_report.status.new'|trans({}, 'messages', currentLocale) }}</option>
                        <option value="in_progress" {% if statusFilter == 'in_progress' %}selected{% endif %}>{{ 'bug_report.status.in_progress'|trans({}, 'messages', currentLocale) }}</option>
                        <option value="resolved" {% if statusFilter == 'resolved' %}selected{% endif %}>{{ 'bug_report.status.resolved'|trans({}, 'messages', currentLocale) }}</option>
                        <option value="reopened" {% if statusFilter == 'reopened' %}selected{% endif %}>{{ 'bug_report.status.reopened'|trans({}, 'messages', currentLocale) }}</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <select class="form-select" name="severity">
                        <option value="">{{ 'admin.bug_reports.filters.severity_all'|trans({}, 'messages', currentLocale) }}</option>
                        <option value="minor" {% if severityFilter == 'minor' %}selected{% endif %}>{{ 'bug_report.severity.minor'|trans({}, 'messages', currentLocale) }}</option>
                        <option value="major" {% if severityFilter == 'major' %}selected{% endif %}>{{ 'bug_report.severity.major'|trans({}, 'messages', currentLocale) }}</option>
                        <option value="critical" {% if severityFilter == 'critical' %}selected{% endif %}>{{ 'bug_report.severity.critical'|trans({}, 'messages', currentLocale) }}</option>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <input class="form-control" type="text" name="route_name" value="{{ routeFilter }}" placeholder="{{ 'admin.bug_reports.filters.route_placeholder'|trans({}, 'messages', currentLocale) }}">
                </div>
                <div class="col-12 col-md-2">
                    <input class="form-control" type="date" name="from_date" value="{{ fromDateFilter }}">
                </div>
                <div class="col-12 col-md-2">
                    <input class="form-control" type="date" name="to_date" value="{{ toDateFilter }}">
                </div>
                <div class="col-12 col-md-2">
                    <div class="form-check mt-2">
                        <input class="form-check-input" id="bug-report-filter-archived" type="checkbox" name="archived" value="1" {% if includeArchived %}checked{% endif %}>
                        <label class="form-check-label" for="bug-report-filter-archived">{{ 'admin.bug_reports.filters.include_archived'|trans({}, 'messages', currentLocale) }}</label>
                    </div>
                </div>
                <div class="col-12 col-md-12">
                    <button class="btn btn-primary w-100" type="submit">{{ 'admin.bug_reports.filters.apply'|trans({}, 'messages', currentLocale) }}</button>
                </div>
            </form>

            <table class="table table-sm align-middle bug-reports-table">
                <thead>
                <tr>
                    <th class="col-date">{{ 'admin.bug_reports.fields.created_at'|trans({}, 'messages', currentLocale) }}</th>
                    <th class="col-ticket">{{ 'admin.bug_reports.fields.ticket'|trans({}, 'messages', currentLocale) }}</th>
                    <th class="col-screenshot d-none d-lg-table-cell">{{ 'admin.bug_reports.fields.screenshot'|trans({}, 'messages', currentLocale) }}</th>
                    <th class="col-action d-none d-lg-table-cell">{{ 'admin.bug_reports.fields.action_short'|trans({}, 'messages', currentLocale) }}</th>
                    <th class="col-observed d-none d-lg-table-cell">{{ 'admin.bug_reports.fields.observed_short'|trans({}, 'messages', currentLocale) }}</th>
                    <th class="col-expected d-none d-lg-table-cell">{{ 'admin.bug_reports.fields.expected_short'|trans({}, 'messages', currentLocale) }}</th>
                    <th class="col-actions text-end">{{ 'admin.bug_reports.fields.actions'|trans({}, 'messages', currentLocale) }}</th>
                </tr>
                </thead>
                <tbody>
                {% for report in reports %}
                    <tr>
                        <td>
                            <span class="d-block">{{ report.createdAt|date('d/m H:i') }}</span>
                            <small class="text-muted text-truncate d-block" title="{{ report.path }}">{{ report.path|bug_report_excerpt(40) }}</small>
                        </td>
                        <td>
                            {% set statusBadge = report.status == 'resolved' ? 'success' : (report.status == 'in_progress' ? 'info' : (report.status == 'reopened' ? 'warning' : 'primary')) %}
                            {% set severityBadge = report.severity == 'critical' ? 'danger' : (report.severity == 'major' ? 'warning' : 'secondary') %}
                            <span class="badge text-bg-{{ statusBadge }} d-block mb-1">{{ ('bug_report.status.' ~ report.status)|trans({}, 'messages', currentLocale) }}</span>
                            <span class="badge text-bg-{{ severityBadge }}">{{ ('bug_report.severity.' ~ report.severity)|trans({}, 'messages', currentLocale) }}</span>
                            {% if report.archived %}
                                <span class="badge text-bg-dark d-block mt-1">{{ 'admin.bug_reports.archived.yes'|trans({}, 'messages', currentLocale) }}</span>
                            {% endif %}
                        </td>
                        <td class="d-none d-lg-table-cell">
                            {% if report.screenshotPath %}
                                <img
                                    src="{{ path('admin_bug_reports_screenshot', { id: report.id }) }}"
                                    alt=""
                                    class="bug-report-screenshot-thumb"
                                    loading="lazy"
                                    data-files-media-preview-trigger
                                    data-src="{{ path('admin_bug_reports_screenshot', { id: report.id }) }}"
                                    data-media-preview-type="image"
                                    data-title="{{ 'admin.bug_reports.detail.title'|trans({'%id%': report.id}, 'messages', currentLocale) }}"
                                    tabindex="0"
                                    role="button"
                                    aria-label="{{ 'media.preview.title'|trans({}, 'messages', currentLocale) }}"
                                >
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="d-none d-lg-table-cell">
                            <span
                                class="bug-report-excerpt"
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                data-bs-html="true"
                                data-bs-custom-class="bug-report-tooltip"
                                data-bs-title="{{ report.actionDescription|bug_report_tooltip_html }}"
                            >{{ report.actionDescription|bug_report_excerpt(80) }}</span>
                        </td>
                        <td class="d-none d-lg-table-cell">
                            <span
                                class="bug-report-excerpt"
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                data-bs-html="true"
                                data-bs-custom-class="bug-report-tooltip"
                                data-bs-title="{{ report.observedResult|bug_report_tooltip_html }}"
                            >{{ report.observedResult|bug_report_excerpt(80) }}</span>
                        </td>
                        <td class="d-none d-lg-table-cell">
                            <span
                                class="bug-report-excerpt"
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                data-bs-html="true"
                                data-bs-custom-class="bug-report-tooltip"
                                data-bs-title="{{ report.expectedResult|bug_report_tooltip_html }}"
                            >{{ report.expectedResult|bug_report_excerpt(80) }}</span>
                        </td>
                        <td class="text-end">
                            <div class="bug-reports-actions">
                                {% if report.status not in ['in_progress', 'resolved'] %}
                                    <form method="post" action="{{ path('admin_bug_reports_status', { id: report.id }) }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrfStatusToken }}">
                                        <input type="hidden" name="status" value="in_progress">
                                        <button
                                            type="submit"
                                            class="btn btn-sm btn-outline-primary"
                                            title="{{ 'admin.bug_reports.actions.mark_in_progress'|trans({}, 'messages', currentLocale) }}"
                                            aria-label="{{ 'admin.bug_reports.actions.mark_in_progress'|trans({}, 'messages', currentLocale) }}"
                                        >
                                            <i class="bi bi-play-fill" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                {% endif %}
                                {% if report.status != 'resolved' %}
                                    <form method="post" action="{{ path('admin_bug_reports_status', { id: report.id }) }}" data-bug-report-resolve-form>
                                        <input type="hidden" name="_csrf_token" value="{{ csrfStatusToken }}">
                                        <input type="hidden" name="status" value="resolved">
                                        <button
                                            type="submit"
                                            class="btn btn-sm btn-outline-success"
                                            title="{{ 'admin.bug_reports.actions.mark_resolved'|trans({}, 'messages', currentLocale) }}"
                                            aria-label="{{ 'admin.bug_reports.actions.mark_resolved'|trans({}, 'messages', currentLocale) }}"
                                            data-bug-report-confirm-resolved="{{ 'admin.bug_reports.actions.confirm_resolved'|trans({}, 'messages', currentLocale) }}"
                                        >
                                            <i class="bi bi-check-lg" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                {% endif %}
                                {% if report.status == 'resolved' and not report.archived %}
                                    <button
                                        type="button"
                                        class="btn btn-sm btn-outline-dark"
                                        title="{{ 'admin.bug_reports.actions.archive'|trans({}, 'messages', currentLocale) }}"
                                        aria-label="{{ 'admin.bug_reports.actions.archive'|trans({}, 'messages', currentLocale) }}"
                                        data-bs-toggle="modal"
                                        data-bs-target="#bugReportArchiveModal"
                                        data-bug-report-archive-url="{{ path('admin_bug_reports_archive', { id: report.id }) }}"
                                    >
                                        <i class="bi bi-archive" aria-hidden="true"></i>
                                    </button>
                                {% endif %}
                                <a class="btn btn-sm btn-outline-secondary" href="{{ path('admin_bug_reports_show', { id: report.id }) }}" title="{{ 'admin.bug_reports.actions.open'|trans({}, 'messages', currentLocale) }}">
                                    <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted">{{ 'admin.bug_reports.list.empty'|trans({}, 'messages', currentLocale) }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% include 'admin/bug_reports/_archive_modal.html.twig' %}
{% endblock %}

{% block extra_scripts %}
    <script>
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((element) => {
            new bootstrap.Tooltip(element);
        });

        document.querySelectorAll('[data-bug-report-resolve-form]').forEach((form) => {
            form.addEventListener('submit', (event) => {
                const button = form.querySelector('[data-bug-report-confirm-resolved]');
                const message = button?.getAttribute('data-bug-report-confirm-resolved') || '';
                if (message !== '' && !window.confirm(message)) {
                    event.preventDefault();
                }
            });
        });
    </script>
{% endblock %}
