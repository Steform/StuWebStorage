{% extends 'base.html.twig' %}
{% set currentLocale = app.request.locale|default('fr') %}

{% block title %}{{ 'admin.download_diagnostics.meta.title'|trans({}, 'messages', currentLocale) }}{% endblock %}

{% block top_navigation %}
    {% include 'components/_storage_admin_nav.html.twig' %}
{% endblock %}

{% block main_container_class %}container-fluid py-4{% endblock %}

{% block body %}
    <h1 class="h4 mb-3">{{ 'admin.download_diagnostics.list.title'|trans({}, 'messages', currentLocale) }}</h1>
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <input class="form-control" type="text" name="download_id" placeholder="{{ 'admin.download_diagnostics.filters.download_id'|trans({}, 'messages', currentLocale) }}" value="{{ filters.downloadId|default('') }}">
        </div>
        <div class="col-md-2">
            <input class="form-control" type="text" name="phase" placeholder="{{ 'admin.download_diagnostics.filters.phase'|trans({}, 'messages', currentLocale) }}" value="{{ filters.phase|default('') }}">
        </div>
        <div class="col-md-2">
            <input class="form-control" type="text" name="status" placeholder="{{ 'admin.download_diagnostics.filters.status'|trans({}, 'messages', currentLocale) }}" value="{{ filters.status|default('') }}">
        </div>
        <div class="col-md-2">
            <input class="form-control" type="text" name="shared_file_id" placeholder="{{ 'admin.download_diagnostics.filters.shared_file_id'|trans({}, 'messages', currentLocale) }}" value="{{ filters.sharedFileId|default('') }}">
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary" type="submit">{{ 'admin.download_diagnostics.filters.apply'|trans({}, 'messages', currentLocale) }}</button>
            <a class="btn btn-outline-secondary" href="{{ path('admin_download_diagnostics_export', app.request.query.all|merge({'format': 'json'})) }}">{{ 'admin.download_diagnostics.export.json'|trans({}, 'messages', currentLocale) }}</a>
            <a class="btn btn-outline-secondary" href="{{ path('admin_download_diagnostics_export', app.request.query.all|merge({'format': 'csv'})) }}">{{ 'admin.download_diagnostics.export.csv'|trans({}, 'messages', currentLocale) }}</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
            <tr>
                <th>{{ 'admin.download_diagnostics.fields.id'|trans({}, 'messages', currentLocale) }}</th>
                <th>{{ 'admin.download_diagnostics.fields.download_id'|trans({}, 'messages', currentLocale) }}</th>
                <th>{{ 'admin.download_diagnostics.fields.phase'|trans({}, 'messages', currentLocale) }}</th>
                <th>{{ 'admin.download_diagnostics.fields.status'|trans({}, 'messages', currentLocale) }}</th>
                <th>{{ 'admin.download_diagnostics.fields.created_at'|trans({}, 'messages', currentLocale) }}</th>
            </tr>
            </thead>
            <tbody>
            {% for event in events %}
                <tr>
                    <td>{{ event.id }}</td>
                    <td><a href="{{ path('admin_download_diagnostics_show', { downloadId: event.downloadId }) }}"><code>{{ event.downloadId }}</code></a></td>
                    <td>{{ event.phase }}</td>
                    <td>{{ event.status }}</td>
                    <td>{{ event.createdAt|date('Y-m-d H:i:s') }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-muted">{{ 'admin.download_diagnostics.list.empty'|trans({}, 'messages', currentLocale) }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
