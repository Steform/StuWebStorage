<!doctype html>
<html lang="{{ locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ blocks.title|default('')|striptags }}</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f8f9fa;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: #212529;
        }
        .email-wrapper {
            width: 100%;
            background-color: #f8f9fa;
            padding: 24px 12px;
        }
        .email-card {
            max-width: 620px;
            margin: 0 auto;
            background: #ffffff;
            border: 1px solid #dee2e6;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,.08);
        }
        .email-header {
            background: linear-gradient(135deg, #0d6efd, #0a58ca);
            color: #ffffff;
            padding: 20px 24px;
        }
        .email-body {
            padding: 24px;
        }
        .cta-block {
            margin: 20px 0;
            text-align: center;
        }
        .cta-button {
            display: inline-block;
            padding: 12px 20px;
            border-radius: 8px;
            background: #0d6efd;
            color: #ffffff !important;
            text-decoration: none;
            font-weight: 600;
        }
        .email-footer {
            border-top: 1px solid #e9ecef;
            padding: 16px 24px 22px;
            font-size: 13px;
            color: #6c757d;
        }
        .small-muted {
            margin-top: 12px;
            font-size: 13px;
            color: #6c757d;
            line-height: 1.5;
        }
        @media (max-width: 600px) {
            .email-header,
            .email-body,
            .email-footer {
                padding: 16px;
            }
        }
    </style>
</head>
<body>
<div class="email-wrapper">
    <div class="email-card">
        <div class="email-header">
            <strong>{{ labels.brand|default('mail.invite.brand'|trans({}, 'messages', locale|default('en'))) }}</strong>
        </div>
        <div class="email-body">
            <div>{{ blocks.title|default('')|raw }}</div>
            <div>{{ blocks.intro|default('')|raw }}</div>
            <div class="cta-block">
                <a class="cta-button" href="{{ activationUrl }}">{{ labels.cta|default('mail.invite.cta'|trans({}, 'messages', locale|default('en'))) }}</a>
            </div>
            <div class="small-muted">{{ blocks.expiry_hint|default('')|raw }}</div>
            <div class="small-muted">{{ blocks.security_hint|default('')|raw }}</div>
        </div>
        <div class="email-footer">
            {{ blocks.footer|default('')|raw }}
        </div>
    </div>
</div>
</body>
</html>
