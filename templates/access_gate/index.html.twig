{% extends 'layouts/storage_landing.html.twig' %}
{% set currentLocale = app.request.locale|default('fr') %}

{% block title %}{{ 'storage.access_gate.meta.title'|trans({}, 'messages', currentLocale) }}{% endblock %}

{% block top_navigation %}{% endblock %}

{% block body %}
<section class="storage-access-gate py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4 p-md-5 text-center">
                        <div class="storage-access-gate__icon mb-3" aria-hidden="true">
                            <i class="bi bi-shield-lock-fill text-primary fs-1"></i>
                        </div>
                        <h1 class="h4 mb-3">{{ 'storage.access_gate.title'|trans({}, 'messages', currentLocale) }}</h1>
                    <p class="text-body-secondary mb-4">
                        {% if gateMessage %}
                            {{ gateMessage }}
                        {% else %}
                            {{ 'storage.access_gate.default_message'|trans({}, 'messages', currentLocale) }}
                        {% endif %}
                    </p>

                    {% include 'components/_flash_messages.html.twig' %}

                    <form method="post" action="{{ path('storage_access_gate_submit') }}" class="text-start">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token(csrfGate) }}">
                            <input type="hidden" name="target" value="{{ target }}">
                            <div class="mb-3">
                                <label for="bypass_note" class="form-label">{{ 'storage.access_gate.bypass_note_label'|trans({}, 'messages', currentLocale) }}</label>
                                <input id="bypass_note" name="bypass_note" type="text" class="form-control" autocomplete="off" required>
                                <div class="form-text">{{ 'storage.access_gate.bypass_note_help'|trans({}, 'messages', currentLocale) }}</div>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">{{ 'storage.access_gate.submit'|trans({}, 'messages', currentLocale) }}</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
