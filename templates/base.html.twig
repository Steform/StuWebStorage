{% set currentLocale = app.request.locale|default('fr') %}
{% set currentTheme = app.request.attributes.get('app_theme', 'light') %}
<!DOCTYPE html>
<html lang="{{ currentLocale }}" data-bs-theme="{{ currentTheme }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ storage_site_title() }} | {% block title %}{{ 'storage.home.meta_title'|trans({}, 'messages', currentLocale) }}{% endblock %}</title>
    {% block favicon %}
        <link rel="icon" type="{{ storage_favicon_type() }}" href="{{ asset(storage_favicon_href()) }}">
    {% endblock %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="{{ asset('css/flash-toasts.css') }}" rel="stylesheet">
    <link href="{{ asset('css/floating-actions.css') }}" rel="stylesheet">
    <link href="{{ asset('css/media-preview.css') }}" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
</head>
<body class="{{ currentTheme == 'dark' ? 'bg-dark text-light theme-dark' : 'bg-light text-dark theme-light' }}">
{% block top_navigation %}
    {% include 'components/_storage_nav.html.twig' %}
{% endblock %}
<main class="{% block main_container_class %}container py-4{% endblock %}">
    {% block flash_messages %}
        {% include 'components/_flash_messages.html.twig' %}
    {% endblock %}
    {% block body %}{% endblock %}
</main>
{% block modals %}{% endblock %}
{% block floating_actions %}
    {% include 'components/_floating_actions.html.twig' %}
{% endblock %}
{% include 'components/_media_preview_modal.html.twig' %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('js/flash-toasts.js') }}" defer></script>
<script src="{{ asset('js/media-preview.js') }}" defer></script>
<script src="{{ asset('js/bug-report-tracker.js') }}" defer></script>
<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js" defer></script>
<script src="{{ asset('js/bug-report-screenshot.js') }}" defer></script>
{% block extra_scripts %}{% endblock %}
</body>
</html>
