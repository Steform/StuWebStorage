{# Shared (grantee) folders + files grid for one admin user pane (`sf_{subject}` folder cursor). #}
{% set folderRootLabel = 'files.folder.root'|trans({}, 'messages', currentLocale) %}
{% set publicShareBadgeAria = 'files.grid.badge.public_aria'|trans({}, 'messages', currentLocale) %}
{% set friendsShareBadgeAria = 'files.grid.badge.friends_aria'|trans({}, 'messages', currentLocale) %}
{% if sharedForMeCurrentFolderId > 0 %}
<nav aria-label="{{ 'files.folder.breadcrumb.aria'|trans({}, 'messages', currentLocale) }}" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({ (sfKey): null })) }}">{{ folderRootLabel }}</a>
        </li>
        {% for sharedFolder in sharedForMeFolders %}
            {% if sharedFolder.id == sharedForMeCurrentFolderId %}
                <li class="breadcrumb-item active" aria-current="page">{{ sharedFolder.name }}</li>
            {% endif %}
        {% endfor %}
    </ol>
</nav>
{% endif %}
<div class="mb-2">
    <div class="form-check m-0">
        <input class="form-check-input" type="checkbox" id="files-select-all-shared-grid-pane-{{ pane.subjectUserId }}" data-files-select-all data-files-select-all-scope="shared" data-files-select-all-pane="{{ pane.paneId }}" aria-label="{{ 'files.selection.aria_select_all'|trans({}, 'messages', currentLocale) }}">
    </div>
</div>
{% if sharedForMeCurrentFolderId == 0 and sharedForMeFolders is not empty %}
    <div class="row g-2 g-md-3 mb-3 files-listing-grid" data-files-pane-scope="{{ pane.paneId }}">
        {% for sharedFolder in sharedForMeFolders %}
            <div class="col-6 col-sm-4 col-md-3 col-lg-2 col-xl-1" data-files-pane-row="{{ pane.paneId }}">
                <div class="card border-0 h-100 files-grid-card files-grid-card-compact files-grid-card-compact--chrome-less position-relative" data-files-shared-folder-id="{{ sharedFolder.id }}">
                    <div class="form-check files-grid-card__select">
                        <input class="form-check-input" type="checkbox" data-files-select-scope="shared" data-files-select-folder-id="{{ sharedFolder.id }}" data-files-pane-id="{{ pane.paneId }}" aria-label="{{ 'files.selection.aria_select_row'|trans({'%name%': sharedFolder.name}, 'messages', currentLocale) }}">
                    </div>
                    <div class="card-body files-grid-card-compact__body d-flex flex-column" data-files-folder-open-url="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({ (sfKey): sharedFolder.id })) }}" tabindex="0" role="button" aria-label="{{ 'files.folder.open'|trans({'%name%': sharedFolder.name}, 'messages', currentLocale) }}">
                        <div class="files-grid-card-compact__preview">
                            <i class="bi bi-folder2-open fs-1 text-warning"></i>
                        </div>
                        <p class="files-grid-card-compact__name small text-muted mb-0 text-truncate" title="{{ sharedFolder.name }}">{{ sharedFolder.name }}</p>
                        <p class="small text-body-secondary mb-0 text-truncate" title="{{ sharedOwnerLabelsByFolderId[sharedFolder.id]|default('-') }}">
                            {{ sharedOwnerLabelsByFolderId[sharedFolder.id]|default('-') }}
                        </p>
                    </div>
                    <div class="dropdown files-actions-dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle d-none" type="button" id="files-shared-folder-actions-{{ pane.paneId }}-grid-{{ sharedFolder.id }}" data-bs-toggle="dropdown" aria-expanded="false">{{ 'files.action.label'|trans({}, 'messages', currentLocale) }}</button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="files-shared-folder-actions-{{ pane.paneId }}-grid-{{ sharedFolder.id }}">
                            {% include 'files/_files_actions_dropdown_scroll_open.html.twig' %}
                            <li><a class="dropdown-item" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({ (sfKey): sharedFolder.id })) }}">{{ 'files.folder.action.open'|trans({}, 'messages', currentLocale) }}</a></li>
                            <li><button type="button" class="dropdown-item" data-files-folder-action="properties" data-files-folder-action-scope="shared" data-files-folder-id="{{ sharedFolder.id }}">{{ 'files.folder.action.properties'|trans({}, 'messages', currentLocale) }}</button></li>
                            <li><a class="dropdown-item" href="{{ path('files_shared_folder_download_zip', {id: sharedFolder.id}) }}">{{ 'files.folder.action.download_zip'|trans({}, 'messages', currentLocale) }}</a></li>
                            {% include 'files/_files_actions_dropdown_scroll_close.html.twig' %}
                        </ul>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
<div class="row g-2 g-md-3 mb-0 files-listing-grid" data-files-selection-scope="shared" data-files-selection-group="shared" data-files-pane-scope="{{ pane.paneId }}">
    {% for file in sharedForMeFiles %}
        {% set ext = file.fileExtension|default('')|lower %}
        {% set isImage = ext in ['png', 'jpg', 'jpeg', 'gif', 'webp', 'svg', 'bmp'] %}
        {% set isPdf = ext in ['pdf'] %}
        {% set isVideo = ext in ['mp4', 'webm', 'ogv', 'mov'] %}
        {% set isAudio = ext in ['mp3', 'mpeg', 'wav', 'ogg', 'm4a', 'aac'] %}
        {% set isText = ext in ['txt', 'log', 'md', 'markdown', 'json', 'csv', 'tsv', 'xml', 'yml', 'yaml', 'ini', 'conf'] %}
        {% set isPreviewStream = isPdf or isVideo or isAudio or isText %}
        {% set isPreviewMedia = isImage or isPreviewStream %}
        {% set publicActive = file.isPublicShareActive %}
        {% set hasFriends = (grantMaps[file.id] ?? [])|length > 0 %}
        <div class="col-6 col-sm-4 col-md-3 col-lg-2 col-xl-1" data-files-pane-row="{{ pane.paneId }}">
            <div class="card border-0 h-100 files-grid-card files-grid-card-compact files-grid-card-compact--chrome-less position-relative">
                <div class="form-check files-grid-card__select">
                    <input class="form-check-input" type="checkbox" id="files-select-shared-grid-pane-{{ pane.subjectUserId }}-{{ file.id }}" data-files-select-id="{{ file.id }}" data-files-select-scope="shared" data-files-pane-id="{{ pane.paneId }}" aria-label="{{ 'files.selection.aria_select_row'|trans({'%name%': file.originalFileName}, 'messages', currentLocale) }}">
                </div>
                <div class="card-body files-grid-card-compact__body d-flex flex-column" data-files-row-target="{{ file.id }}" tabindex="0" role="button" aria-label="{{ 'files.grid.open_actions_aria'|trans({'%name%': file.originalFileName}, 'messages', currentLocale) }}">
                    <div class="files-grid-card-compact__preview{% if isPreviewMedia %} files-grid-card-compact__preview--media-trigger{% endif %}">
                        {% if isImage %}
                            <img src="{{ path('files_download', { id: file.id }) }}" alt="{{ file.originalFileName }}" class="files-grid-card-compact__preview-image" loading="lazy" data-files-media-preview-trigger data-src="{{ path('files_download', { id: file.id }) }}" data-media-preview-type="image" data-title="{{ file.originalFileName }}" data-alt="{{ file.originalFileName }}" tabindex="0" role="button" aria-label="{{ 'files.action.preview'|trans({}, 'messages', currentLocale) }}: {{ file.originalFileName }}">
                        {% else %}
                            {% if isPreviewStream %}
                                <div class="files-grid-card-compact__preview-stream-trigger d-inline-flex align-items-center justify-content-center{% if isPdf %} files-grid-card-compact__preview-pdf-trigger{% endif %}" data-files-media-preview-trigger data-src="{{ path('files_preview', { id: file.id }) }}" data-media-preview-type="{{ isPdf ? 'pdf' : (isVideo ? 'video' : (isAudio ? 'audio' : 'text')) }}" data-title="{{ file.originalFileName }}" tabindex="0" role="button" aria-label="{{ 'files.action.preview'|trans({}, 'messages', currentLocale) }}: {{ file.originalFileName }}">
                                    {% include 'components/_file_type_icon.html.twig' with { extension: ext, size: 'grid' } %}
                                </div>
                            {% else %}
                                {% include 'components/_file_type_icon.html.twig' with { extension: ext, size: 'grid' } %}
                            {% endif %}
                        {% endif %}
                    </div>
                    {% if publicActive or hasFriends %}
                        <span class="files-grid-card-compact__share-badges" aria-hidden="true">
                            {% if publicActive %}
                                <i class="bi bi-globe files-grid-card-compact__share-badge-icon" title="{{ publicShareBadgeAria }}" aria-label="{{ publicShareBadgeAria }}"></i>
                            {% endif %}
                            {% if hasFriends %}
                                <i class="bi bi-people-fill files-grid-card-compact__share-badge-icon" title="{{ friendsShareBadgeAria }}" aria-label="{{ friendsShareBadgeAria }}"></i>
                            {% endif %}
                        </span>
                    {% endif %}
                    <p class="files-grid-card-compact__name small text-muted mb-0 text-truncate" title="{{ file.originalFileName }}">{{ file.originalFileName }}</p>
                    <p class="small text-body-secondary mb-0 text-truncate" title="{{ sharedOwnerLabelsByFileId[file.id]|default('-') }}">
                        {{ sharedOwnerLabelsByFileId[file.id]|default('-') }}
                    </p>
                    {% include 'files/_file_actions_dropdown_shared_for_me.html.twig' with { file: file } %}
                </div>
            </div>
        </div>
    {% else %}
        {% if sharedForMeCurrentFolderId > 0 or sharedForMeFolders is empty %}
            <div class="col-12">
                <p class="text-muted">{{ (listingScope|default('both') == 'shared' ? 'files.listing_scope.empty_shared' : 'files.section.shared_for_me_empty')|trans({}, 'messages', currentLocale) }}</p>
            </div>
        {% endif %}
    {% endfor %}
</div>
