<div
    class="modal fade"
    id="textFileEditorModal"
    tabindex="-1"
    aria-labelledby="textFileEditorModalTitle"
    aria-hidden="true"
    data-text-editor-preview-url-template="{{ path('files_preview', { id: 999999 }) }}"
    data-text-editor-save-url-template="{{ path('files_content_save', { id: 999999 }) }}"
    data-text-editor-csrf="{{ csrf_token(csrfContentEdit) }}"
    data-text-editor-title="{{ 'files.text_editor.title'|trans({}, 'messages', currentLocale) }}"
    data-text-editor-save="{{ 'files.text_editor.save'|trans({}, 'messages', currentLocale) }}"
    data-text-editor-cancel="{{ 'files.text_editor.cancel'|trans({}, 'messages', currentLocale) }}"
    data-text-editor-unsaved="{{ 'files.text_editor.unsaved'|trans({}, 'messages', currentLocale) }}"
    data-text-editor-tab-edit="{{ 'files.text_editor.tab_edit'|trans({}, 'messages', currentLocale) }}"
    data-text-editor-tab-preview="{{ 'files.text_editor.tab_preview'|trans({}, 'messages', currentLocale) }}"
    data-text-editor-load-error="{{ 'files.text_editor.load_error'|trans({}, 'messages', currentLocale) }}"
    data-text-editor-save-error="{{ 'files.text_editor.save_error'|trans({}, 'messages', currentLocale) }}"
    data-text-editor-close-confirm="{{ 'files.text_editor.close_confirm'|trans({}, 'messages', currentLocale) }}"
>
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="textFileEditorModalTitle">{{ 'files.text_editor.title'|trans({}, 'messages', currentLocale) }}</h2>
                <span class="badge text-bg-warning d-none ms-2" id="textFileEditorUnsavedBadge" data-text-editor-unsaved-badge>{{ 'files.text_editor.unsaved'|trans({}, 'messages', currentLocale) }}</span>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'files.upload.modal_close'|trans({}, 'messages', currentLocale) }}"></button>
            </div>
            <div class="modal-body text-file-editor-modal-body">
                <p id="textFileEditorLoadError" class="alert alert-danger d-none mb-3" role="alert"></p>
                <p id="textFileEditorSaveError" class="alert alert-danger d-none mb-3" role="alert"></p>
                <ul class="nav nav-tabs d-none mb-3" id="textFileEditorTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="textFileEditorTabEditBtn" data-bs-toggle="tab" data-bs-target="#textFileEditorTabEdit" type="button" role="tab" aria-controls="textFileEditorTabEdit" aria-selected="true">{{ 'files.text_editor.tab_edit'|trans({}, 'messages', currentLocale) }}</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="textFileEditorTabPreviewBtn" data-bs-toggle="tab" data-bs-target="#textFileEditorTabPreview" type="button" role="tab" aria-controls="textFileEditorTabPreview" aria-selected="false">{{ 'files.text_editor.tab_preview'|trans({}, 'messages', currentLocale) }}</button>
                    </li>
                </ul>
                <div class="tab-content" id="textFileEditorTabContent">
                    <div class="tab-pane fade show active" id="textFileEditorTabEdit" role="tabpanel" aria-labelledby="textFileEditorTabEditBtn" tabindex="0">
                        <div id="textFileEditorMount" class="text-file-editor-mount" aria-label="{{ 'files.text_editor.tab_edit'|trans({}, 'messages', currentLocale) }}"></div>
                    </div>
                    <div class="tab-pane fade" id="textFileEditorTabPreview" role="tabpanel" aria-labelledby="textFileEditorTabPreviewBtn" tabindex="0">
                        <div id="textFileEditorMarkdownPreview" class="text-file-editor-markdown-preview"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" data-text-editor-cancel>{{ 'files.text_editor.cancel'|trans({}, 'messages', currentLocale) }}</button>
                <button type="button" class="btn btn-primary" id="textFileEditorSaveBtn" data-text-editor-save disabled>{{ 'files.text_editor.save'|trans({}, 'messages', currentLocale) }}</button>
            </div>
        </div>
    </div>
</div>
