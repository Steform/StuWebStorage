<div
    class="modal fade"
    id="filesDownloadPrepareModal"
    tabindex="-1"
    aria-labelledby="filesDownloadPrepareModalTitle"
    aria-hidden="true"
    data-files-download-prepare-url-template="{{ path('files_download_prepare', { id: 999999 }) }}"
    data-files-download-prepare-tick-url-template="{{ path('files_download_prepare_tick', { jobId: '00000000000000000000000000000000' }) }}"
    data-files-download-prepare-cancel-url-template="{{ path('files_download_prepare_cancel', { jobId: '00000000000000000000000000000000' }) }}"
    data-files-download-prepare-deliver-url-template="{{ path('files_download_prepare_deliver', { jobId: '00000000000000000000000000000000' }) }}"
    data-msg-error="{{ 'files.download_prepare.modal.error_generic'|trans({}, 'messages', currentLocale)|e('html_attr') }}"
    data-msg-progress="{{ 'files.download_prepare.modal.progress'|trans({}, 'messages', currentLocale)|e('html_attr') }}"
    data-msg-cancel-confirm="{{ 'files.download_prepare.modal.cancel_confirm'|trans({}, 'messages', currentLocale)|e('html_attr') }}"
>
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="filesDownloadPrepareModalTitle">{{ 'files.download_prepare.modal.title'|trans({}, 'messages', currentLocale) }}</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" data-files-download-prepare-dismiss aria-label="{{ 'files.download_prepare.modal.close_aria'|trans({}, 'messages', currentLocale) }}"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" value="{{ csrf_token(csrfDownloadPrepare) }}" data-files-download-prepare-csrf-input>
                <p class="mb-3"><strong data-files-download-prepare-file-name>—</strong></p>
                <p class="small text-muted mb-3">{{ 'files.download_prepare.modal.hint'|trans({}, 'messages', currentLocale) }}</p>
                <div id="files-download-prepare-error" class="alert alert-danger d-none" role="alert" aria-live="assertive"></div>
                <div id="files-download-prepare-progress-wrap">
                    <p class="small text-muted mb-1" id="files-download-prepare-phase" aria-live="polite"></p>
                    <div class="progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" id="files-download-prepare-progress">
                        <div id="files-download-prepare-progress-bar" class="progress-bar"></div>
                    </div>
                    <p class="small text-muted mb-0 mt-1" id="files-download-prepare-count" aria-live="polite"></p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-files-download-prepare-cancel>{{ 'files.download_prepare.modal.cancel'|trans({}, 'messages', currentLocale) }}</button>
            </div>
        </div>
    </div>
</div>
