{% extends 'base.html.twig' %}
{% set currentLocale = app.request.locale|default('fr') %}
{% block title %}{{ 'files.download_progress.page_title'|trans({}, 'messages', currentLocale) }}{% endblock %}
{% block main_container_class %}container py-4{% endblock %}
{% block body %}
<div
    id="files-download-progress-page"
    class="row justify-content-center"
    data-file-name="{{ sharedFile.originalFileName|e('html_attr') }}"
    data-token-url="{{ tokenUrl|e('html_attr') }}"
    data-download-url="{{ downloadUrl|e('html_attr') }}"
    data-csrf-token="{{ csrf_token(csrfDownloadToken)|e('html_attr') }}"
    data-msg-error="{{ 'files.download_progress.error_generic'|trans({}, 'messages', currentLocale)|e('html_attr') }}"
>
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h1 class="h4 mb-3">{{ 'files.download_progress.page_title'|trans({}, 'messages', currentLocale) }}</h1>
                <p class="mb-2"><strong>{{ sharedFile.originalFileName }}</strong></p>
                <p class="text-body-secondary small mb-4">{{ 'files.download_progress.hint'|trans({}, 'messages', currentLocale) }}</p>
                <div id="files-download-progress-error" class="alert alert-danger d-none" role="alert"></div>
                <div class="progress mb-2" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
                    <div id="files-download-progress-bar" class="progress-bar" style="width: 0%"></div>
                </div>
                <p class="small text-muted mb-3" id="files-download-progress-count" aria-live="polite"></p>
                <button type="button" class="btn btn-outline-secondary" id="files-download-progress-cancel">{{ 'files.download_progress.cancel'|trans({}, 'messages', currentLocale) }}</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}
{% block extra_scripts %}
    <script src="{{ asset('js/files-download-manager.js') }}?v=20260707" defer></script>
    <script src="{{ asset('js/files-download-progress-page.js') }}?v=20260707" defer></script>
{% endblock %}
