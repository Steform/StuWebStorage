{% extends 'base.html.twig' %}
{% set currentLocale = app.request.locale|default('fr') %}

{% block stylesheets %}
    <link href="{{ asset('css/files-space.css') }}?v=20260504-pane-accordion" rel="stylesheet">
{% endblock %}

{% block title %}{{ 'files.meta.title'|trans({}, 'messages', currentLocale) }}{% endblock %}

{% block main_container_class %}container-fluid p-0{% endblock %}

{% block flash_messages %}
    {% if not adminContext|default(false) %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block top_navigation %}
    {% if adminContext|default(false) %}
        {% include 'components/_storage_admin_nav.html.twig' %}
    {% endif %}
    <nav class="navbar navbar-expand bg-body-tertiary border-bottom files-top-nav shadow-sm">
        <div class="container-fluid px-3 py-2">
            <div class="d-flex flex-column align-items-stretch gap-2 gap-md-3 w-100 files-top-nav__stack">
                <div class="input-group input-group-sm files-nav-search flex-grow-1 min-w-0 w-100 files-top-nav__search files-toolbar-slot files-toolbar-slot--search">
                    <span class="input-group-text files-search-prefix">
                        <img src="{{ asset('images/files/loupe.svg') }}" alt="" class="files-search-prefix__icon" aria-hidden="true">
                        <span class="visually-hidden">{{ 'files.toolbar.search_label'|trans({}, 'messages', currentLocale) }}</span>
                    </span>
                    <input class="form-control" id="files-search-q" type="text" name="files_search_ui" value="{{ searchQueryValue }}" autocomplete="off" placeholder="{{ 'files.toolbar.search_placeholder'|trans({}, 'messages', currentLocale) }}" aria-label="{{ 'files.toolbar.search_label'|trans({}, 'messages', currentLocale) }}" inputmode="search">
                    {% set searchHasGlob = (searchQueryValue is defined and searchQueryValue is not null) and (searchQueryValue matches '/[*?]/') %}
                    {% set showSearchClear = searchQueryValue|length > 3 or (searchHasGlob and searchQueryValue|length >= 2) %}
                    <button type="button" id="files-search-clear" class="btn btn-outline-secondary files-search-clear{% if not showSearchClear %} d-none{% endif %}" aria-label="{{ 'files.search.clear_aria'|trans({}, 'messages', currentLocale) }}">&times;</button>
                </div>
                <div class="d-flex flex-wrap gap-2 align-items-center w-100 files-top-nav__toolbar-tools">
                    <div class="files-toolbar-mobile-line files-toolbar-md-contents d-flex flex-wrap w-100 align-items-center gap-2 files-toolbar-second-row">
                    <div class="files-toolbar-lead-cluster d-flex align-items-center gap-2 flex-shrink-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm files-toolbar-slot files-toolbar-slot--filter" data-bs-toggle="modal" data-bs-target="#filesAdvancedFiltersModal">{{ 'files.nav.filter'|trans({}, 'messages', currentLocale) }}</button>
                    {% if is_granted('ROLE_SHARE_SEND') %}
                    <div class="dropdown files-toolbar-slot files-toolbar-slot--action">
                        <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" id="files-action-global-toggle" data-bs-toggle="dropdown" aria-expanded="false" aria-label="{{ 'files.action.menu.global_aria'|trans({}, 'messages', currentLocale) }}">
                            <span data-files-action-global-label data-msg-template="{{ 'files.toolbar.action_global'|trans({ '%count%': '%count%' }, 'messages', currentLocale) }}">{{ 'files.toolbar.action_global'|trans({'%count%': '0'}, 'messages', currentLocale) }}</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-start" aria-labelledby="files-action-global-toggle">
                            <li>
                                <button type="button" class="dropdown-item" id="files-open-upload-modal" data-bs-toggle="modal" data-bs-target="#filesUploadModal">{{ 'files.toolbar.send'|trans({}, 'messages', currentLocale) }}</button>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <button type="button" class="dropdown-item" data-files-action-global="create-folder" data-files-action-scope="owned">{{ 'files.action.create_folder'|trans({}, 'messages', currentLocale) }}</button>
                            </li>
                            <li>
                                <button type="button" class="dropdown-item" data-files-action-global="download-selection" data-files-action-scope="both" data-files-action-requires-selection="1">{{ 'files.action.download_selection'|trans({}, 'messages', currentLocale) }}</button>
                            </li>
                            <li>
                                <button type="button" class="dropdown-item" data-files-action-global="move-selection" data-files-action-scope="owned" data-files-action-requires-selection="1">{{ 'files.action.move_selection'|trans({}, 'messages', currentLocale) }}</button>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <button type="button" class="dropdown-item text-danger" data-files-action-global="delete" data-files-action-scope="owned" data-files-action-requires-selection="1">{{ 'files.action.delete_selection'|trans({}, 'messages', currentLocale) }}</button>
                            </li>
                        </ul>
                    </div>
                    {% endif %}
                    </div>
                    <div class="dropdown files-toolbar-slot files-toolbar-slot--display files-toolbar-slot--view flex-shrink-0">
                        {# data-bs-auto-close must live on the toggle: Bootstrap reads Dropdown config from the toggle only; "outside" keeps the panel open for clicks inside the menu (required for nested dropend submenus). #}
                        <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" id="files-display-menu-toggle" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" aria-label="{{ 'files.toolbar.display_menu_aria'|trans({}, 'messages', currentLocale) }}">
                            {{ 'files.toolbar.display_menu_label'|trans({}, 'messages', currentLocale) }}
                        </button>
                        <ul class="dropdown-menu" aria-labelledby="files-display-menu-toggle">
                            <li class="dropend files-display-submenu files-display-submenu--scope">
                                <button type="button" class="dropdown-toggle files-display-submenu-trigger d-flex align-items-center justify-content-between w-100 text-start" id="files-display-submenu-scope-toggle" data-bs-toggle="dropdown" aria-expanded="false" aria-haspopup="true" aria-label="{{ 'files.toolbar.listing_scope_group_aria'|trans({}, 'messages', currentLocale) }}">{{ 'files.toolbar.display_section_scope'|trans({}, 'messages', currentLocale) }}</button>
                                <ul class="dropdown-menu" aria-labelledby="files-display-submenu-scope-toggle">
                                    {% if adminContext|default(false) %}
                                    <li>
                                        <a class="dropdown-item{% if adminViewScope|default('owner') == 'owner' %} active{% endif %}" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'admin_context': '1', 'admin_view_scope': 'owner'})) }}" data-files-admin-view-scope="owner">{{ 'files.admin.view_scope_owner'|trans({}, 'messages', currentLocale) }}</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item{% if adminViewScope|default('owner') == 'all' %} active{% endif %}" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'admin_context': '1', 'admin_view_scope': 'all', 'owner': null, 'view_scope': 'all', 'subject_user': null})) }}" data-files-admin-view-scope="all">{{ 'files.admin.view_scope_all'|trans({}, 'messages', currentLocale) }}</a>
                                    </li>
                                    {% if is_granted('ROLE_SHARE_SEND') %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item{% if listingScope|default('both') == 'owned' %} active{% endif %}" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'admin_context': '1', 'listing_scope': 'owned'})) }}" data-files-listing-scope="owned">{{ 'files.toolbar.listing_scope_owned'|trans({}, 'messages', currentLocale) }}</a>
                                    </li>
                                    {% endif %}
                                    <li>
                                        <a class="dropdown-item{% if listingScope|default('both') == 'shared' %} active{% endif %}" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'admin_context': '1', 'listing_scope': 'shared'})) }}" data-files-listing-scope="shared">{{ 'files.toolbar.listing_scope_shared'|trans({}, 'messages', currentLocale) }}</a>
                                    </li>
                                    {% if is_granted('ROLE_SHARE_SEND') %}
                                    <li>
                                        <a class="dropdown-item{% if listingScope|default('both') == 'both' %} active{% endif %}" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'admin_context': '1', 'listing_scope': 'both'})) }}" data-files-listing-scope="both">{{ 'files.toolbar.listing_scope_both'|trans({}, 'messages', currentLocale) }}</a>
                                    </li>
                                    {% endif %}
                                    {% elseif is_granted('ROLE_SHARE_SEND') %}
                                    <li>
                                        <a class="dropdown-item{% if listingScope|default('both') == 'owned' %} active{% endif %}" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'listing_scope': 'owned'})) }}" data-files-listing-scope="owned">{{ 'files.toolbar.listing_scope_owned'|trans({}, 'messages', currentLocale) }}</a>
                                    </li>
                                    {% endif %}
                                    {% if not adminContext|default(false) %}
                                    <li>
                                        <a class="dropdown-item{% if listingScope|default('both') == 'shared' %} active{% endif %}" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'listing_scope': 'shared'})) }}" data-files-listing-scope="shared">{{ 'files.toolbar.listing_scope_shared'|trans({}, 'messages', currentLocale) }}</a>
                                    </li>
                                    {% if is_granted('ROLE_SHARE_SEND') %}
                                    <li>
                                        <a class="dropdown-item{% if listingScope|default('both') == 'both' %} active{% endif %}" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'listing_scope': 'both'})) }}" data-files-listing-scope="both">{{ 'files.toolbar.listing_scope_both'|trans({}, 'messages', currentLocale) }}</a>
                                    </li>
                                    {% endif %}
                                    {% endif %}
                                </ul>
                            </li>
                            <li class="dropend files-display-submenu files-display-submenu--layout">
                                <button type="button" class="dropdown-toggle files-display-submenu-trigger d-flex align-items-center justify-content-between w-100 text-start" id="files-display-submenu-layout-toggle" data-bs-toggle="dropdown" aria-expanded="false" aria-haspopup="true" aria-label="{{ 'files.view.toggle_aria'|trans({}, 'messages', currentLocale) }}">{{ 'files.toolbar.display_section_layout'|trans({}, 'messages', currentLocale) }}</button>
                                <ul class="dropdown-menu" aria-labelledby="files-display-submenu-layout-toggle">
                                    <li>
                                        <a class="dropdown-item{% if layoutView == 'list' %} active{% endif %}" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'view': 'list'})) }}" data-files-view-toggle="list">{{ 'files.view.list'|trans({}, 'messages', currentLocale) }}</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item{% if layoutView == 'grid' %} active{% endif %}" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'view': 'grid'})) }}" data-files-view-toggle="grid">{{ 'files.view.grid'|trans({}, 'messages', currentLocale) }}</a>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                    {% if adminContext|default(false) %}
                    <form method="get" action="{{ path(filesIndexRoute|default('files_index')) }}" class="d-flex flex-wrap align-items-center gap-2{% if adminViewScope|default('owner') != 'owner' %} d-none{% endif %}" data-files-admin-owner-filter-block{% if adminViewScope|default('owner') != 'owner' %} aria-hidden="true"{% endif %}>
                        <input type="hidden" name="admin_context" value="1">
                        <input type="hidden" name="admin_view_scope" value="owner">
                        {% if listingScope is defined and listingScope != 'both' %}
                        <input type="hidden" name="listing_scope" value="{{ listingScope }}">
                        {% endif %}
                        <input type="hidden" id="files-admin-owner-hidden" name="owner" value="{{ adminOwnerFilterValue|default('') }}">
                        <label class="form-label mb-0 small text-nowrap" for="files-admin-owner-search">{{ 'files.admin.owner_filter_label'|trans({}, 'messages', currentLocale) }}</label>
                        <input type="text" class="form-control form-control-sm files-admin-owner-filter-input" id="files-admin-owner-search" name="owner_query" value="{{ adminOwnerQueryValue|default('') }}" autocomplete="off" list="files-admin-owner-suggest-list" data-files-admin-owner-search data-files-admin-owner-filter-control{% if adminViewScope|default('owner') != 'owner' %} disabled{% endif %}>
                        <datalist id="files-admin-owner-suggest-list"></datalist>
                        <button type="submit" class="btn btn-outline-secondary btn-sm" data-files-admin-owner-filter-control{% if adminViewScope|default('owner') != 'owner' %} disabled{% endif %}>{{ 'files.admin.owner_filter_apply'|trans({}, 'messages', currentLocale) }}</button>
                    </form>
                    {% endif %}
                    {% if layoutView == 'list' %}
                        <div class="dropdown files-toolbar-slot files-toolbar-slot--columns d-none d-md-block" data-files-columns-dropdown>
                            <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle"
                                    id="files-columns-toggle"
                                    data-bs-toggle="dropdown"
                                    data-bs-auto-close="outside"
                                    aria-expanded="false"
                                    aria-label="{{ 'files.toolbar.columns_aria'|trans({}, 'messages', currentLocale) }}">
                                {{ 'files.toolbar.columns_label'|trans({}, 'messages', currentLocale) }}
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end p-2" aria-labelledby="files-columns-toggle">
                                <li>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="files-col-toggle-type"
                                               data-files-col-toggle="type">
                                        <label class="form-check-label" for="files-col-toggle-type">
                                            {{ 'files.table.extension'|trans({}, 'messages', currentLocale) }}
                                        </label>
                                    </div>
                                </li>
                                <li>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="files-col-toggle-size"
                                               data-files-col-toggle="size">
                                        <label class="form-check-label" for="files-col-toggle-size">
                                            {{ 'files.table.size'|trans({}, 'messages', currentLocale) }}
                                        </label>
                                    </div>
                                </li>
                                <li>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="files-col-toggle-share-public"
                                               data-files-col-toggle="share_public">
                                        <label class="form-check-label" for="files-col-toggle-share-public">
                                            {{ 'files.table.share_public'|trans({}, 'messages', currentLocale) }}
                                        </label>
                                    </div>
                                </li>
                                <li>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="files-col-toggle-share-friends"
                                               data-files-col-toggle="share_friends">
                                        <label class="form-check-label" for="files-col-toggle-share-friends">
                                            {{ 'files.table.share_friends'|trans({}, 'messages', currentLocale) }}
                                        </label>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="files-col-toggle-uploaded"
                                               data-files-col-toggle="uploaded">
                                        <label class="form-check-label" for="files-col-toggle-uploaded">
                                            {{ 'files.table.uploaded'|trans({}, 'messages', currentLocale) }}
                                        </label>
                                    </div>
                                </li>
                                <li>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="files-col-toggle-modified"
                                               data-files-col-toggle="modified">
                                        <label class="form-check-label" for="files-col-toggle-modified">
                                            {{ 'files.table.modified'|trans({}, 'messages', currentLocale) }}
                                        </label>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    {% endif %}
                    {% if adminContext|default(false) %}
                    <div class="files-admin-scope-badge ms-md-auto" data-files-admin-scope-badge data-msg-scope-all="{{ 'files.admin.view_scope_all'|trans({}, 'messages', currentLocale)|e('html_attr') }}">
                        <span class="text-body-secondary">{{ 'files.toolbar.display_section_scope'|trans({}, 'messages', currentLocale) }} :</span>
                        <strong data-files-admin-scope-badge-label>{{ adminScopeBannerLabel|default('') }}</strong>
                    </div>
                    {% endif %}
                    <div class="files-toolbar-cluster-view-home d-none d-md-flex align-items-center gap-2 flex-shrink-0{% if not adminContext|default(false) %} ms-auto{% endif %}">
                        <a class="btn btn-outline-secondary btn-sm files-toolbar-slot files-toolbar-slot--home" href="{{ path('app_home') }}">{{ 'app.nav.home'|trans({}, 'messages', currentLocale) }}</a>
                    </div>
                    <a class="btn btn-outline-secondary btn-sm files-toolbar-slot files-toolbar-slot--home files-toolbar-home-mobile d-md-none ms-md-auto flex-shrink-0" href="{{ path('app_home') }}">{{ 'app.nav.home'|trans({}, 'messages', currentLocale) }}</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>
{% endblock %}

{% block body %}
<div class="files-space-page{% if app.request.attributes.get('_route') == 'admin_files_index' %} files-space-page--admin-files-route{% endif %}">
    {% if adminContext|default(false) and adminOwnerFallbackApplied|default(false) and adminOwnerFallbackNotice|default('') != '' %}
    <div class="alert alert-info mb-3 mx-3" role="status">
        {{ adminOwnerFallbackNotice }}
    </div>
    {% endif %}
    <div class="modal fade" id="filesAdvancedFiltersModal" tabindex="-1" aria-labelledby="filesAdvancedFiltersTitle" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="filesAdvancedFiltersTitle">{{ 'files.advanced.title'|trans({}, 'messages', currentLocale) }}</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'files.advanced.close'|trans({}, 'messages', currentLocale) }}"></button>
                </div>
                <form method="get" action="{{ path(filesIndexRoute|default('files_index')) }}" id="files-modal-filters-form">
                    <div class="modal-body">
                        {% if adminContext|default(false) %}
                            <input type="hidden" name="admin_context" value="1">
                            <input type="hidden" name="owner" value="{{ adminOwnerFilterValue|default('') }}">
                        {% endif %}
                        <input type="hidden" name="q" id="files-modal-field-q" value="{{ listingCriteria.searchQuery }}">
                        {% if listingScope is defined and listingScope != 'both' %}
                            <input type="hidden" name="listing_scope" value="{{ listingScope }}">
                        {% endif %}
                        <div id="files-advanced-filters-i18n" class="d-none" aria-hidden="true"
                            data-msg-ext-all="{{ 'files.advanced.extensions_button_all'|trans({}, 'messages', currentLocale) }}"
                            data-msg-ext-count="{{ 'files.advanced.extensions_button_count'|trans({}, 'messages', currentLocale) }}"
                            data-msg-grantee-all="{{ 'files.advanced.grantees_button_all'|trans({}, 'messages', currentLocale) }}"
                            data-msg-grantee-count="{{ 'files.advanced.grantees_button_count'|trans({}, 'messages', currentLocale) }}"
                            data-msg-select-all="{{ 'files.advanced.filter_select_all'|trans({}, 'messages', currentLocale) }}"
                            data-msg-clear="{{ 'files.advanced.filter_clear_selection'|trans({}, 'messages', currentLocale) }}"></div>
                        {% if listingScope is defined and listingScope in ['both', 'owned'] %}
                            <p class="form-text border-start border-3 border-secondary ps-2 mb-3">{{ 'files.advanced.filters_owned_list_hint'|trans({}, 'messages', currentLocale) }}</p>
                        {% elseif listingScope is defined and listingScope == 'shared' %}
                            <p class="form-text border-start border-3 border-secondary ps-2 mb-3">{{ 'files.advanced.filters_shared_list_hint'|trans({}, 'messages', currentLocale) }}</p>
                        {% endif %}
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="adv-filter-public">{{ 'files.toolbar.filter_public_label'|trans({}, 'messages', currentLocale) }}</label>
                                <select class="form-select" id="adv-filter-public" name="filter_public">
                                    <option value="" {% if filterPublicValue == '' %}selected{% endif %}>{{ 'files.toolbar.filter_public_all'|trans({}, 'messages', currentLocale) }}</option>
                                    <option value="yes" {% if filterPublicValue == 'yes' %}selected{% endif %}>{{ 'files.toolbar.filter_public_yes'|trans({}, 'messages', currentLocale) }}</option>
                                    <option value="no" {% if filterPublicValue == 'no' %}selected{% endif %}>{{ 'files.toolbar.filter_public_no'|trans({}, 'messages', currentLocale) }}</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="adv-view">{{ 'files.advanced.view_layout'|trans({}, 'messages', currentLocale) }}</label>
                                <select class="form-select" id="adv-view" name="view">
                                    <option value="list" {% if layoutView == 'list' %}selected{% endif %}>{{ 'files.view.list'|trans({}, 'messages', currentLocale) }}</option>
                                    <option value="grid" {% if layoutView == 'grid' %}selected{% endif %}>{{ 'files.view.grid'|trans({}, 'messages', currentLocale) }}</option>
                                </select>
                            </div>
                            {% if allowedExtensions is not empty %}
                                <div class="col-12 files-adv-filter" data-files-adv-filter="extensions">
                                    <span class="form-label d-block" id="adv-extensions-heading">{{ 'files.toolbar.extensions_label'|trans({}, 'messages', currentLocale) }}</span>
                                    <div class="dropdown">
                                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center" type="button" id="adv-ext-dropdown-btn" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" aria-labelledby="adv-extensions-heading" aria-controls="adv-ext-dropdown-panel" title="{{ 'files.advanced.extensions_dropdown_aria'|trans({}, 'messages', currentLocale) }}">
                                            <span data-files-adv-filter-label>{% set extPick = listingCriteria.extensionFilters|default([])|length %}{{ extPick > 0 ? 'files.advanced.extensions_button_count'|trans({'%count%': extPick}, 'messages', currentLocale) : 'files.advanced.extensions_button_all'|trans({}, 'messages', currentLocale) }}</span>
                                        </button>
                                        <div class="dropdown-menu w-100 p-2 shadow files-filter-dropdown-panel" id="adv-ext-dropdown-panel" aria-labelledby="adv-ext-dropdown-btn">
                                            <div class="d-flex flex-wrap gap-2 mb-2 px-1">
                                                <button type="button" class="btn btn-sm btn-outline-primary" data-files-adv-filter-action="all" data-files-adv-filter-target="extensions">{{ 'files.advanced.filter_select_all'|trans({}, 'messages', currentLocale) }}</button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary" data-files-adv-filter-action="none" data-files-adv-filter-target="extensions">{{ 'files.advanced.filter_clear_selection'|trans({}, 'messages', currentLocale) }}</button>
                                            </div>
                                            <div class="files-filter-dropdown-scroll px-1">
                                                {% for ext in allowedExtensions %}
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" name="ext[]" value="{{ ext }}" id="adv-ext-{{ ext }}" {% if ext in listingRetain.extensions|default([]) %}checked{% endif %}>
                                                        <label class="form-check-label" for="adv-ext-{{ ext }}">.{{ ext }}</label>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                            <div class="col-md-6">
                                <label class="form-label" for="adv-sort">{{ 'files.toolbar.sort_label'|trans({}, 'messages', currentLocale) }}</label>
                                <select class="form-select" id="adv-sort" name="sort">
                                    <option value="" {% if sortField == '' %}selected{% endif %}>{{ 'files.table.sort.state.none'|trans({}, 'messages', currentLocale) }}</option>
                                    <option value="name" {% if sortField == 'name' %}selected{% endif %}>{{ 'files.toolbar.sort_name'|trans({}, 'messages', currentLocale) }}</option>
                                    <option value="size" {% if sortField == 'size' %}selected{% endif %}>{{ 'files.toolbar.sort_size'|trans({}, 'messages', currentLocale) }}</option>
                                    <option value="uploaded" {% if sortField == 'uploaded' %}selected{% endif %}>{{ 'files.toolbar.sort_uploaded'|trans({}, 'messages', currentLocale) }}</option>
                                    <option value="modified" {% if sortField == 'modified' %}selected{% endif %}>{{ 'files.toolbar.sort_modified'|trans({}, 'messages', currentLocale) }}</option>
                                    <option value="type" {% if sortField == 'ext' %}selected{% endif %}>{{ 'files.toolbar.sort_ext'|trans({}, 'messages', currentLocale) }}</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="adv-dir">{{ 'files.toolbar.dir_label'|trans({}, 'messages', currentLocale) }}</label>
                                <select class="form-select" id="adv-dir" name="dir">
                                    <option value="" {% if sortDirection == '' %}selected{% endif %}>{{ 'files.table.sort.state.none'|trans({}, 'messages', currentLocale) }}</option>
                                    <option value="asc" {% if sortDirection == 'asc' %}selected{% endif %}>{{ 'files.toolbar.dir_asc'|trans({}, 'messages', currentLocale) }}</option>
