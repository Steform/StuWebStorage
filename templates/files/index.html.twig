            data-files-ui-pref-authenticated="{{ app.user ? '1' : '0' }}"
            data-files-admin-owner-suggest-url="{{ path('admin_files_owner_suggest') }}"
            data-files-admin-owner-resolve-url="{{ path('admin_files_owner_resolve') }}"
            aria-live="polite"
            aria-busy="false"
        >
            {% include 'files/_listing_fragment.html.twig' %}
        </div>
    </div>
</div>
{% endblock %}

