{# Listing region for live search partial; no pagination (Sprint 19); decoupled public/friends share columns (Sprint 22). #}
{% if listingChips is not empty %}
    <div class="files-filter-chips d-flex flex-wrap gap-2 align-items-center mb-3">
        {% for chip in listingChips %}
            <a class="badge rounded-pill text-bg-secondary text-decoration-none files-filter-chip" href="{{ path(filesIndexRoute|default('files_index'), chip.query) }}">{{ chip.label_key|trans(chip.label_params|default({}), 'messages', currentLocale) }} <span aria-hidden="true">&times;</span></a>
        {% endfor %}
    </div>
{% endif %}
{% if hasAdvancedFilters %}
    <div class="mb-3">
        <a class="btn btn-sm btn-outline-secondary" href="{{ path(filesIndexRoute|default('files_index'), listingQueryResetAdvanced) }}">{{ 'files.advanced.reset_only'|trans({}, 'messages', currentLocale) }}</a>
    </div>
{% endif %}

{% set hasActiveCriteria = listingChips is not empty or hasAdvancedFilters %}
{% set expirationActiveAria = 'files.share.expiration_active_aria'|trans({}, 'messages', currentLocale) %}
{% set publicShareBadgeAria = 'files.grid.badge.public_aria'|trans({}, 'messages', currentLocale) %}
{% set friendsShareBadgeAria = 'files.grid.badge.friends_aria'|trans({}, 'messages', currentLocale) %}
{% set sharedForMeTitle = 'files.section.shared_for_me'|trans({}, 'messages', currentLocale) %}
{% set myFilesTitle = 'files.section.my_files'|trans({}, 'messages', currentLocale) %}
{% set folderRootLabel = 'files.folder.root'|trans({}, 'messages', currentLocale) %}
{% set folderLandingMap = folderPublicLandingUrls|default({}) %}
{% set myFilesAccordionHeadingId = 'filesSectionMyFilesHeading' %}
{% set myFilesAccordionCollapseId = 'filesSectionMyFilesCollapse' %}
{% set sharedAccordionHeadingId = 'filesSectionSharedForMeHeading' %}
{% set sharedAccordionCollapseId = 'filesSectionSharedForMeCollapse' %}
{% set usePanes = useUserFilesPanes|default(false) %}
{% set debugOwnerIds = {} %}
{% for dbgFile in files %}
    {% set debugOwnerIds = debugOwnerIds|merge({(dbgFile.ownerUserId): 1}) %}
{% endfor %}
{% set currentSortField = listingCriteria.sortField|default('') %}
{% set currentSortDirection = listingCriteria.sortDirection|default('') %}
{% set sortCycle = {
    '': {'dir': 'desc', 'icon': 'bi-arrow-down-up', 'ariaSort': 'none', 'labelKey': 'files.table.sort.state.none'},
    'desc': {'dir': 'asc', 'icon': 'bi-sort-down', 'ariaSort': 'descending', 'labelKey': 'files.table.sort.state.desc'},
    'asc': {'dir': '', 'icon': 'bi-sort-up', 'ariaSort': 'ascending', 'labelKey': 'files.table.sort.state.asc'}
} %}
<div class="accordion files-sections-accordion mb-4" id="files-sections-accordion">
    <div class="d-none" data-files-debug-state data-files-debug-files-count="{{ files|length }}" data-files-debug-owner-distinct="{{ debugOwnerIds|length }}" data-files-debug-owner-groups="0" data-files-debug-admin-all="0" data-files-debug-admin-share-users="{{ adminAllShareUsersCount|default(0) }}"></div>
    {% if usePanes %}
        {% include 'files/components/_users_pane_pagination.html.twig' %}
        {% for pane in userFilesPanes|default([]) %}
            {% include 'files/components/_user_files_pane.html.twig' with { pane: pane, isFirstPane: loop.first } %}
        {% endfor %}
    {% elseif showOwnedListingSection %}
    <div class="accordion-item mb-5">
        <h2 class="accordion-header" id="{{ myFilesAccordionHeadingId }}">
            <button
                class="accordion-button"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#{{ myFilesAccordionCollapseId }}"
                aria-expanded="true"
                aria-controls="{{ myFilesAccordionCollapseId }}"
                data-files-section-toggle="my_files"
            >
                {{ myFilesTitle }}
            </button>
        </h2>
        <div
            id="{{ myFilesAccordionCollapseId }}"
            class="accordion-collapse collapse show"
            aria-labelledby="{{ myFilesAccordionHeadingId }}"
            data-files-section="my_files"
        >
            <div class="accordion-body pb-0">
{% if currentFolder is not null %}
{% set breadcrumbQueryBase = listingQuery|merge({'folder': null}) %}
<nav aria-label="{{ 'files.folder.breadcrumb.aria'|trans({}, 'messages', currentLocale) }}" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            {# Contract anchor: path('files_index', breadcrumbQueryBase) #}
            <a href="{{ path(filesIndexRoute|default('files_index'), breadcrumbQueryBase) }}">{{ folderRootLabel }}</a>
        </li>
        {% for breadcrumbFolder in breadcrumbFolders %}
            {% if loop.last %}
                <li class="breadcrumb-item active" aria-current="page">{{ breadcrumbFolder.name }}</li>
            {% else %}
                <li class="breadcrumb-item">
                    <a href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'folder': breadcrumbFolder.id})) }}">{{ breadcrumbFolder.name }}</a>
                </li>
            {% endif %}
        {% endfor %}
    </ol>
</nav>
{% endif %}
{% if currentFolder is not null %}
    {% if currentFolderPublicLandingUrl is defined and currentFolderPublicLandingUrl != '' %}
<div class="mb-3 d-flex flex-wrap align-items-center gap-2">
    <button type="button" class="btn btn-sm btn-outline-secondary" data-files-row-action="copy-public-link" data-files-public-url="{{ currentFolderPublicLandingUrl }}" aria-label="{{ 'files.action.copy_public_link_aria'|trans({}, 'messages', currentLocale) }}">{{ 'files.action.copy_public_link'|trans({}, 'messages', currentLocale) }}</button>
    {% if currentFolder.publicPasswordGateActive %}
    <button type="button" class="btn btn-sm btn-outline-secondary" data-files-folder-action="copy-public-link-with-password" data-files-folder-id="{{ currentFolder.id }}" data-files-public-url="{{ currentFolderPublicLandingUrl }}" aria-label="{{ 'files.action.copy_public_link_with_password_aria'|trans({}, 'messages', currentLocale) }}">{{ 'files.action.copy_public_link_with_password'|trans({}, 'messages', currentLocale) }}</button>
    {% endif %}
</div>
    {% elseif currentFolderShareState is defined and currentFolderShareState.publicActive and is_granted('ROLE_SHARE_PUBLIC') %}
<div class="mb-3 d-flex flex-wrap align-items-center gap-2">
    <button type="button" class="btn btn-sm btn-outline-secondary" data-files-folder-action="resolve-copy-public-link" data-files-folder-id="{{ currentFolder.id }}" aria-label="{{ 'files.action.copy_public_link_aria'|trans({}, 'messages', currentLocale) }}">{{ 'files.action.copy_public_link'|trans({}, 'messages', currentLocale) }}</button>
</div>
    {% endif %}
{% endif %}
{% if layoutView == 'grid' %}
    <div class="row g-2 g-md-3 mb-0 files-listing-grid" data-files-selection-scope="owned" data-files-selection-group="owned">
        {% for folder in folders %}
            {% set folderState = folderShareStates[folder.id]|default({'publicActive': false, 'friendsActive': false, 'filesInSubtree': 0, 'hasPublicExpiration': false}) %}
            <div class="col-6 col-sm-4 col-md-3 col-lg-2 col-xl-1">
                <div class="card border-0 h-100 files-grid-card files-grid-card-compact files-grid-card-compact--chrome-less position-relative">
                    <div class="card-body files-grid-card-compact__body d-flex flex-column" data-files-folder-open-url="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'folder': folder.id})) }}" tabindex="0" role="button" aria-label="{{ 'files.folder.open'|trans({'%name%': folder.name}, 'messages', currentLocale) }}">
                        <div class="files-grid-card-compact__preview">
                            <i class="bi bi-folder2-open fs-1 text-warning"></i>
                        </div>
                        {% if folderState.publicActive or folderState.friendsActive %}
                            <span class="files-grid-card-compact__share-badges" aria-hidden="true">
                                {% if folderState.publicActive %}
                                    <i class="bi bi-globe files-grid-card-compact__share-badge-icon" title="{{ publicShareBadgeAria }}" aria-label="{{ publicShareBadgeAria }}"></i>
                                {% endif %}
                                {% if folderState.friendsActive %}
                                    <i class="bi bi-people-fill files-grid-card-compact__share-badge-icon" title="{{ friendsShareBadgeAria }}" aria-label="{{ friendsShareBadgeAria }}"></i>
                                {% endif %}
                            </span>
                        {% endif %}
                        <p class="files-grid-card-compact__name small text-muted mb-0 text-truncate" title="{{ folder.name }}">{{ folder.name }}</p>
                    </div>
                    <div class="dropdown files-actions-dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle d-none" type="button" id="files-folder-actions-{{ folder.id }}" data-bs-toggle="dropdown" aria-expanded="false">{{ 'files.action.label'|trans({}, 'messages', currentLocale) }}</button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="files-folder-actions-{{ folder.id }}">
                            {% include 'files/_files_actions_dropdown_scroll_open.html.twig' %}
                            <li><a class="dropdown-item" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'folder': folder.id})) }}">{{ 'files.folder.action.open'|trans({}, 'messages', currentLocale) }}</a></li>
                            <li><button type="button" class="dropdown-item" data-files-folder-action="properties" data-files-folder-id="{{ folder.id }}">{{ 'files.folder.action.properties'|trans({}, 'messages', currentLocale) }}</button></li>
                            <li><button type="button" class="dropdown-item" data-files-folder-action="share-public" data-files-folder-id="{{ folder.id }}">{{ 'files.folder.action.share_public'|trans({}, 'messages', currentLocale) }}</button></li>
                            <li><button type="button" class="dropdown-item" data-files-folder-action="share-friends" data-files-folder-id="{{ folder.id }}">{{ 'files.folder.action.share_friends'|trans({}, 'messages', currentLocale) }}</button></li>
                            <li><button type="button" class="dropdown-item" data-files-folder-action="rename-open" data-files-folder-id="{{ folder.id }}" data-files-folder-name="{{ folder.name }}">{{ 'files.folder.action.rename'|trans({}, 'messages', currentLocale) }}</button></li>
                            {% if folderLandingMap[folder.id] is defined and folderLandingMap[folder.id] != '' %}
                            <li><button type="button" class="dropdown-item" data-files-row-action="copy-public-link" data-files-public-url="{{ folderLandingMap[folder.id] }}" aria-label="{{ 'files.action.copy_public_link_aria'|trans({}, 'messages', currentLocale) }}">{{ 'files.action.copy_public_link'|trans({}, 'messages', currentLocale) }}</button></li>
                            {% if folder.publicPasswordGateActive %}
                            <li><button type="button" class="dropdown-item" data-files-folder-action="copy-public-link-with-password" data-files-folder-id="{{ folder.id }}" data-files-public-url="{{ folderLandingMap[folder.id] }}" aria-label="{{ 'files.action.copy_public_link_with_password_aria'|trans({}, 'messages', currentLocale) }}">{{ 'files.action.copy_public_link_with_password'|trans({}, 'messages', currentLocale) }}</button></li>
                            {% endif %}
                            {% elseif folderState.publicActive and is_granted('ROLE_SHARE_PUBLIC') %}
                            <li><button type="button" class="dropdown-item" data-files-folder-action="resolve-copy-public-link" data-files-folder-id="{{ folder.id }}" aria-label="{{ 'files.action.copy_public_link_aria'|trans({}, 'messages', currentLocale) }}">{{ 'files.action.copy_public_link'|trans({}, 'messages', currentLocale) }}</button></li>
                            {% endif %}
                            <li><a class="dropdown-item" href="{{ path('files_folder_download_zip', {id: folder.id}) }}">{{ 'files.folder.action.download_zip'|trans({}, 'messages', currentLocale) }}</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><button type="button" class="dropdown-item text-danger" data-files-folder-delete-open data-files-folder-id="{{ folder.id }}" data-files-folder-name="{{ folder.name }}" data-files-folder-delete-action="{{ path('files_folder_delete', {id: folder.id}) }}" data-files-folder-delete-csrf="{{ csrf_token(csrfFolderDelete) }}">{{ 'files.folder.action.delete'|trans({}, 'messages', currentLocale) }}</button></li>
                            {% include 'files/_files_actions_dropdown_scroll_close.html.twig' %}
                        </ul>
                    </div>
                </div>
            </div>
        {% endfor %}
        {% for file in files %}
            {# Preview stream extensions: align with FilesController::PREVIEW_STREAM_BY_EXTENSION #}
            {% set ext = file.fileExtension|default('')|lower %}
            {% set isImage = ext in ['png', 'jpg', 'jpeg', 'gif', 'webp', 'svg', 'bmp'] %}
            {% set isPdf = ext in ['pdf'] %}
            {% set isVideo = ext in ['mp4', 'webm', 'ogv', 'mov'] %}
            {% set isAudio = ext in ['mp3', 'mpeg', 'wav', 'ogg', 'm4a', 'aac'] %}
            {% set isText = ext in ['txt', 'log', 'md', 'markdown', 'json', 'csv', 'tsv', 'xml', 'yml', 'yaml', 'ini', 'conf'] %}
            {% set isPreviewStream = isPdf or isVideo or isAudio or isText %}
            {% set isPreviewMedia = isImage or isPreviewStream %}
            {% set publicActive = file.isPublicShareActive %}
            {% set hasFriends = (grantMaps[file.id] ?? [])|length > 0 %}
            <div class="col-6 col-sm-4 col-md-3 col-lg-2 col-xl-1">
                <div class="card border-0 h-100 files-grid-card files-grid-card-compact files-grid-card-compact--chrome-less position-relative">
                    <div class="form-check files-grid-card__select">
                        <input class="form-check-input" type="checkbox" id="files-select-grid-{{ file.id }}" data-files-select-id="{{ file.id }}" data-files-select-scope="owned" aria-label="{{ 'files.selection.aria_select_row'|trans({'%name%': file.originalFileName}, 'messages', currentLocale) }}">
                    </div>
                    <div class="card-body files-grid-card-compact__body d-flex flex-column" data-files-row-target="{{ file.id }}" tabindex="0" role="button" aria-label="{{ 'files.grid.open_actions_aria'|trans({'%name%': file.originalFileName}, 'messages', currentLocale) }}">
                        <div class="files-grid-card-compact__preview{% if isPreviewMedia %} files-grid-card-compact__preview--media-trigger{% endif %}">
                            {% if isImage %}
                                <img
                                    src="{{ path('files_download', { id: file.id }) }}"
                                    alt="{{ file.originalFileName }}"
                                    class="files-grid-card-compact__preview-image"
                                    loading="lazy"
                                    data-files-media-preview-trigger
                                    data-src="{{ path('files_download', { id: file.id }) }}"
                                    data-media-preview-type="image"
                                    data-title="{{ file.originalFileName }}"
                                    data-alt="{{ file.originalFileName }}"
                                    tabindex="0"
                                    role="button"
                                    aria-label="{{ 'files.action.preview'|trans({}, 'messages', currentLocale) }}: {{ file.originalFileName }}"
                                >
                            {% else %}
                                {% if isPreviewStream %}
                                    <div
                                        class="files-grid-card-compact__preview-stream-trigger d-inline-flex align-items-center justify-content-center{% if isPdf %} files-grid-card-compact__preview-pdf-trigger{% endif %}"
                                        data-files-media-preview-trigger
                                        data-src="{{ path('files_preview', { id: file.id }) }}"
                                        data-media-preview-type="{{ isPdf ? 'pdf' : (isVideo ? 'video' : (isAudio ? 'audio' : 'text')) }}"
                                        data-title="{{ file.originalFileName }}"
                                        {% if isText %}
                                        {% include 'files/_media_preview_owned_text_attrs.html.twig' with { file: file, fileExt: ext } %}
                                        {% endif %}
                                        tabindex="0"
                                        role="button"
                                        aria-label="{{ 'files.action.preview'|trans({}, 'messages', currentLocale) }}: {{ file.originalFileName }}"
                                    >
                                        {% include 'components/_file_type_icon.html.twig' with { extension: ext, filename: file.originalFileName, size: 'grid' } %}
                                    </div>
                                {% else %}
                                    {% include 'components/_file_type_icon.html.twig' with { extension: ext, filename: file.originalFileName, size: 'grid' } %}
                                {% endif %}
                            {% endif %}
                        </div>
                        {% if publicActive or hasFriends %}
                            <span class="files-grid-card-compact__share-badges" aria-hidden="true">
                                {% if publicActive %}
                                    <i class="bi bi-globe files-grid-card-compact__share-badge-icon" title="{{ publicShareBadgeAria }}" aria-label="{{ publicShareBadgeAria }}"></i>
                                {% endif %}
                                {% if hasFriends %}
                                    <i class="bi bi-people-fill files-grid-card-compact__share-badge-icon" title="{{ friendsShareBadgeAria }}" aria-label="{{ friendsShareBadgeAria }}"></i>
                                {% endif %}
                            </span>
                        {% endif %}
                        <p class="files-grid-card-compact__name small text-muted mb-0 text-truncate" title="{{ file.originalFileName }}">{{ file.originalFileName }}</p>
                        {% if adminContext|default(false) and ownerLabelsByFileId[file.id] is defined %}
                            <p class="small text-body-secondary mb-0 text-truncate" title="{{ ownerLabelsByFileId[file.id] }}">
                                {{ 'files.admin.owner_badge'|trans({'%owner%': ownerLabelsByFileId[file.id]}, 'messages', currentLocale) }}
                            </p>
                        {% endif %}
                        {% include 'files/_file_actions_dropdown.html.twig' with { file: file } %}
                    </div>
                </div>
            </div>
        {% else %}
            {% if folders is empty %}
                <div class="col-12">
                    {% set emptyMessageKey = hasActiveCriteria ? 'files.list.filtered_empty' : (isCurrentFolderCompletelyEmpty ? 'files.list.folder_empty' : (listingScope|default('both') == 'owned' ? 'files.listing_scope.empty_owned' : 'files.list.empty')) %}
                    <p class="text-muted">{{ emptyMessageKey|trans({}, 'messages', currentLocale) }}</p>
                </div>
            {% endif %}
        {% endfor %}
{% else %}
    <div class="d-none d-md-block table-responsive mb-0 files-listing-table-wrap">
        <table class="table table-striped table-hover align-middle w-100 files-owned-list-table" data-files-selection-scope="owned" data-files-selection-group="owned">
            <thead class="files-table-head">
                <tr>
                    <th scope="col" class="files-col-select text-start">
                        <div class="form-check m-0">
                            <input class="form-check-input" type="checkbox" id="files-select-all" data-files-select-all data-files-select-all-scope="owned" aria-label="{{ 'files.selection.aria_select_all'|trans({}, 'messages', currentLocale) }}">
                        </div>
                    </th>
                    {% set typeState = currentSortField == 'ext' ? currentSortDirection : '' %}
                    {% set typeCycle = sortCycle[typeState] %}
                    <th scope="col" class="files-col-icon text-start text-nowrap" data-files-col="type" aria-sort="{{ typeCycle.ariaSort }}">
                        <a class="btn btn-link btn-sm p-0 text-decoration-none" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'sort': typeCycle.dir == '' ? null : 'type', 'dir': typeCycle.dir == '' ? null : typeCycle.dir})) }}">
                            {{ 'files.table.extension'|trans({}, 'messages', currentLocale) }}
                            <i class="bi {{ typeCycle.icon }} ms-1" aria-hidden="true"></i>
                            <span class="visually-hidden">{{ typeCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
                        </a>
                    </th>
                    {% set nameState = currentSortField == 'name' ? currentSortDirection : '' %}
                    {% set nameCycle = sortCycle[nameState] %}
                    <th scope="col" class="text-start w-100" aria-sort="{{ nameCycle.ariaSort }}">
                        <a class="btn btn-link btn-sm p-0 text-decoration-none" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'sort': nameCycle.dir == '' ? null : 'name', 'dir': nameCycle.dir == '' ? null : nameCycle.dir})) }}">
                            {{ 'files.table.name'|trans({}, 'messages', currentLocale) }}
                            <i class="bi {{ nameCycle.icon }} ms-1" aria-hidden="true"></i>
                            <span class="visually-hidden">{{ nameCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
                        </a>
                    </th>
                    {% set sizeState = currentSortField == 'size' ? currentSortDirection : '' %}
                    {% set sizeCycle = sortCycle[sizeState] %}
                    <th scope="col" class="text-end text-nowrap" data-files-col="size" aria-sort="{{ sizeCycle.ariaSort }}">
                        <div class="d-flex justify-content-end">
                            <a class="btn btn-link btn-sm p-0 text-decoration-none d-inline-flex align-items-center justify-content-end text-end" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'sort': sizeCycle.dir == '' ? null : 'size', 'dir': sizeCycle.dir == '' ? null : sizeCycle.dir})) }}">
                                {{ 'files.table.size'|trans({}, 'messages', currentLocale) }}
                                <i class="bi {{ sizeCycle.icon }} ms-1" aria-hidden="true"></i>
                                <span class="visually-hidden">{{ sizeCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
                            </a>
                        </div>
                    </th>
                    {% set uploadedState = currentSortField == 'uploaded' ? currentSortDirection : '' %}
                    {% set uploadedCycle = sortCycle[uploadedState] %}
                    <th scope="col" class="d-none text-end text-nowrap" data-files-col="uploaded" aria-sort="{{ uploadedCycle.ariaSort }}">
                        <div class="d-flex justify-content-end">
                            <a class="btn btn-link btn-sm p-0 text-decoration-none d-inline-flex align-items-center justify-content-end text-end" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'sort': uploadedCycle.dir == '' ? null : 'uploaded', 'dir': uploadedCycle.dir == '' ? null : uploadedCycle.dir})) }}">
                                {{ 'files.table.uploaded'|trans({}, 'messages', currentLocale) }}
                                <i class="bi {{ uploadedCycle.icon }} ms-1" aria-hidden="true"></i>
                                <span class="visually-hidden">{{ uploadedCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
                            </a>
                        </div>
                    </th>
                    {% set modifiedState = currentSortField == 'modified' ? currentSortDirection : '' %}
                    {% set modifiedCycle = sortCycle[modifiedState] %}
                    <th scope="col" class="d-none text-end text-nowrap" data-files-col="modified" aria-sort="{{ modifiedCycle.ariaSort }}">
                        <div class="d-flex justify-content-end">
                            <a class="btn btn-link btn-sm p-0 text-decoration-none d-inline-flex align-items-center justify-content-end text-end" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'sort': modifiedCycle.dir == '' ? null : 'modified', 'dir': modifiedCycle.dir == '' ? null : modifiedCycle.dir})) }}">
                                {{ 'files.table.modified'|trans({}, 'messages', currentLocale) }}
                                <i class="bi {{ modifiedCycle.icon }} ms-1" aria-hidden="true"></i>
                                <span class="visually-hidden">{{ modifiedCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
                            </a>
                        </div>
                    </th>
                    {% set publicState = currentSortField == 'share_public' ? currentSortDirection : '' %}
                    {% set publicCycle = sortCycle[publicState] %}
                    <th scope="col" class="text-start text-nowrap" data-files-col="share_public" aria-sort="{{ publicCycle.ariaSort }}">
                        <div class="d-flex justify-content-start">
                            <a class="btn btn-link btn-sm p-0 text-decoration-none d-inline-flex align-items-center justify-content-start text-start" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'sort': publicCycle.dir == '' ? null : 'share_public', 'dir': publicCycle.dir == '' ? null : publicCycle.dir})) }}">
                                {{ 'files.table.share_public'|trans({}, 'messages', currentLocale) }}
                                <i class="bi {{ publicCycle.icon }} ms-1" aria-hidden="true"></i>
                                <span class="visually-hidden">{{ publicCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
                            </a>
                        </div>
                    </th>
                    {% set friendsState = currentSortField == 'share_friends' ? currentSortDirection : '' %}
                    {% set friendsCycle = sortCycle[friendsState] %}
                    <th scope="col" class="text-start text-nowrap" data-files-col="share_friends" aria-sort="{{ friendsCycle.ariaSort }}">
                        <div class="d-flex justify-content-start">
                            <a class="btn btn-link btn-sm p-0 text-decoration-none d-inline-flex align-items-center justify-content-start text-start" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'sort': friendsCycle.dir == '' ? null : 'share_friends', 'dir': friendsCycle.dir == '' ? null : friendsCycle.dir})) }}">
                                {{ 'files.table.share_friends'|trans({}, 'messages', currentLocale) }}
                                <i class="bi {{ friendsCycle.icon }} ms-1" aria-hidden="true"></i>
                                <span class="visually-hidden">{{ friendsCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
                            </a>
                        </div>
                    </th>
                    <th scope="col" class="files-col-actions"><span class="visually-hidden">{{ 'files.table.actions'|trans({}, 'messages', currentLocale) }}</span></th>
                </tr>
            </thead>
            <tbody>
            {% for folder in folders %}
                {% set folderState = folderShareStates[folder.id]|default({'publicActive': false, 'friendsActive': false, 'filesInSubtree': 0, 'hasPublicExpiration': false}) %}
                <tr>
                    <td class="files-col-select text-start">
                        <div class="form-check m-0">
                            <input class="form-check-input" type="checkbox" data-files-select-scope="owned" data-files-select-folder-id="{{ folder.id }}" aria-label="{{ 'files.selection.aria_select_row'|trans({'%name%': folder.name}, 'messages', currentLocale) }}">
                        </div>
                    </td>
