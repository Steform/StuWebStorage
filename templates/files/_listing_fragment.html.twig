                    <th scope="col" class="files-col-icon text-start text-nowrap" data-files-col="type" aria-sort="{{ typeCycle.ariaSort }}">
                        <a class="btn btn-link btn-sm p-0 text-decoration-none" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'sort': typeCycle.dir == '' ? null : 'type', 'dir': typeCycle.dir == '' ? null : typeCycle.dir})) }}">
                            {{ 'files.table.extension'|trans({}, 'messages', currentLocale) }}
                            <i class="bi {{ typeCycle.icon }} ms-1" aria-hidden="true"></i>
                            <span class="visually-hidden">{{ typeCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
                        </a>
                    </th>
                    {% set nameState = currentSortField == 'name' ? currentSortDirection : '' %}
                    {% set nameCycle = sortCycle[nameState] %}
                    <th scope="col" class="text-start w-100" aria-sort="{{ nameCycle.ariaSort }}">
                        <a class="btn btn-link btn-sm p-0 text-decoration-none" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'sort': nameCycle.dir == '' ? null : 'name', 'dir': nameCycle.dir == '' ? null : nameCycle.dir})) }}">
                            {{ 'files.table.name'|trans({}, 'messages', currentLocale) }}
                            <i class="bi {{ nameCycle.icon }} ms-1" aria-hidden="true"></i>
                            <span class="visually-hidden">{{ nameCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
                        </a>
                    </th>
                    {% set sizeState = currentSortField == 'size' ? currentSortDirection : '' %}
                    {% set sizeCycle = sortCycle[sizeState] %}
                    {% set pseudoState = currentSortField == 'pseudo' ? currentSortDirection : '' %}
                    {% set pseudoCycle = sortCycle[pseudoState] %}
                    <th scope="col" class="text-start text-nowrap" data-files-col="owner-pseudo" aria-sort="{{ pseudoCycle.ariaSort }}">
                        <a class="btn btn-link btn-sm p-0 text-decoration-none" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'sort': pseudoCycle.dir == '' ? null : 'pseudo', 'dir': pseudoCycle.dir == '' ? null : pseudoCycle.dir})) }}">
                            {{ 'files.table.pseudo'|trans({}, 'messages', currentLocale) }}
                            <i class="bi {{ pseudoCycle.icon }} ms-1" aria-hidden="true"></i>
                            <span class="visually-hidden">{{ pseudoCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
                        </a>
                    </th>
                    <th scope="col" class="text-end text-nowrap" data-files-col="size" aria-sort="{{ sizeCycle.ariaSort }}">
                        <a class="btn btn-link btn-sm p-0 text-decoration-none" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'sort': sizeCycle.dir == '' ? null : 'size', 'dir': sizeCycle.dir == '' ? null : sizeCycle.dir})) }}">
                            {{ 'files.table.size'|trans({}, 'messages', currentLocale) }}
                            <i class="bi {{ sizeCycle.icon }} ms-1" aria-hidden="true"></i>
                            <span class="visually-hidden">{{ sizeCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
                        </a>
                    </th>
                    <th scope="col" class="files-col-actions"><span class="visually-hidden">{{ 'files.table.actions'|trans({}, 'messages', currentLocale) }}</span></th>
                </tr>
            </thead>
            <tbody>
                {% for sharedFolder in sharedForMeFolders %}
                        <tr data-files-shared-folder-id="{{ sharedFolder.id }}">
                            <td class="files-col-select text-start">
                                <div class="form-check m-0">
                                    <input class="form-check-input" type="checkbox" data-files-select-scope="shared" data-files-select-folder-id="{{ sharedFolder.id }}" aria-label="{{ 'files.selection.aria_select_row'|trans({'%name%': sharedFolder.name}, 'messages', currentLocale) }}">
                                </div>
                            </td>
                            <td class="files-col-icon files-row-clickable text-start" data-files-col="type" data-files-folder-open-url="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'shared_folder': sharedFolder.id})) }}">
                                <i class="bi bi-folder2-open text-warning"></i>
                            </td>
                            <td class="text-break files-col-name files-row-clickable text-start w-100" data-files-folder-open-url="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'shared_folder': sharedFolder.id})) }}" title="{{ sharedFolder.name }}">
                                {{ sharedFolder.name }}
                            </td>
                            <td class="text-start text-nowrap" data-files-col="owner-pseudo" title="{{ ownerLabelsByFolderId[sharedFolder.id]|default('-') }}">{{ ownerLabelsByFolderId[sharedFolder.id]|default('-') }}</td>
                            <td class="text-end text-nowrap" data-files-col="size">{{ (sharedFolderSizeBytes[sharedFolder.id]|default(0))|files_size_format }}</td>
                            <td class="files-actions-anchor-cell">
                                <div class="dropdown files-actions-dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="files-shared-folder-actions-{{ sharedFolder.id }}" data-bs-toggle="dropdown" aria-expanded="false">{{ 'files.action.label'|trans({}, 'messages', currentLocale) }}</button>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="files-shared-folder-actions-{{ sharedFolder.id }}">
                                        {% include 'files/_files_actions_dropdown_scroll_open.html.twig' %}
                                        <li><a class="dropdown-item" href="{{ path(filesIndexRoute|default('files_index'), listingQuery|merge({'shared_folder': sharedFolder.id})) }}">{{ 'files.folder.action.open'|trans({}, 'messages', currentLocale) }}</a></li>
                                        <li><button type="button" class="dropdown-item" data-files-folder-action="properties" data-files-folder-action-scope="shared" data-files-folder-id="{{ sharedFolder.id }}">{{ 'files.folder.action.properties'|trans({}, 'messages', currentLocale) }}</button></li>
                                        <li><a class="dropdown-item" href="{{ path('files_shared_folder_download_zip', {id: sharedFolder.id}) }}">{{ 'files.folder.action.download_zip'|trans({}, 'messages', currentLocale) }}</a></li>
                                        {% include 'files/_files_actions_dropdown_scroll_close.html.twig' %}
                                    </ul>
                                </div>
                            </td>
                        </tr>
                {% endfor %}
                {% for file in sharedForMeFiles %}
                    <tr>
                        <td class="files-col-select text-start">
                            <div class="form-check m-0">
                                <input class="form-check-input" type="checkbox" id="files-select-shared-row-{{ file.id }}" data-files-select-id="{{ file.id }}" data-files-select-scope="shared" aria-label="{{ 'files.selection.aria_select_row'|trans({'%name%': file.originalFileName}, 'messages', currentLocale) }}">
                            </div>
                        </td>
                        {% set ext = file.fileExtension|default('')|lower %}
                        {% set isListImageShared = ext in ['png', 'jpg', 'jpeg', 'gif', 'webp', 'svg', 'bmp'] %}
                        {% set isListPdfShared = ext in ['pdf'] %}
                        {% set isListVideoShared = ext in ['mp4', 'webm', 'ogv', 'mov'] %}
                        {% set isListAudioShared = ext in ['mp3', 'mpeg', 'wav', 'ogg', 'm4a', 'aac'] %}
                        {% set isListTextShared = ext in ['txt', 'log', 'md', 'markdown', 'json', 'csv', 'tsv', 'xml', 'yml', 'yaml', 'ini', 'conf'] %}
                        {% set isListStreamShared = isListPdfShared or isListVideoShared or isListAudioShared or isListTextShared %}
                        {% set isListPreviewableShared = isListImageShared or isListStreamShared %}
                        <td
                            class="files-col-icon files-row-clickable text-start{% if isListPreviewableShared %} files-col-icon--previewable{% endif %}"
                            data-files-col="type"
                            data-files-row-target="{{ file.id }}"
                            {% if isListPreviewableShared %}
                            data-files-media-preview-trigger
                            {% if isListImageShared %}
                            data-src="{{ path('files_download', { id: file.id }) }}"
                            data-media-preview-type="image"
                            data-title="{{ file.originalFileName }}"
                            data-alt="{{ file.originalFileName }}"
                            {% elseif isListPdfShared %}
                            data-src="{{ path('files_preview', { id: file.id }) }}"
                            data-media-preview-type="pdf"
                            data-title="{{ file.originalFileName }}"
                            {% elseif isListVideoShared %}
                            data-src="{{ path('files_preview', { id: file.id }) }}"
                            data-media-preview-type="video"
                            data-title="{{ file.originalFileName }}"
                            {% elseif isListAudioShared %}
                            data-src="{{ path('files_preview', { id: file.id }) }}"
                            data-media-preview-type="audio"
                            data-title="{{ file.originalFileName }}"
                            {% elseif isListTextShared %}
                            data-src="{{ path('files_preview', { id: file.id }) }}"
                            data-media-preview-type="text"
                            data-title="{{ file.originalFileName }}"
                            {% endif %}
                            {% endif %}
                        >
                            {% include 'components/_file_type_icon.html.twig' with { extension: ext, filename: file.originalFileName, size: 'list' } %}
                        </td>
                        <td
                            class="text-break files-col-name files-row-clickable text-start w-100{% if isListPreviewableShared %} files-col-name--previewable{% endif %}"
                            data-files-row-target="{{ file.id }}"
                            title="{{ file.originalFileName }}"
                            {% if isListPreviewableShared %}
                            data-files-media-preview-trigger
                            {% if isListImageShared %}
                            data-src="{{ path('files_download', { id: file.id }) }}"
                            data-media-preview-type="image"
                            data-title="{{ file.originalFileName }}"
                            data-alt="{{ file.originalFileName }}"
                            {% elseif isListPdfShared %}
                            data-src="{{ path('files_preview', { id: file.id }) }}"
                            data-media-preview-type="pdf"
                            data-title="{{ file.originalFileName }}"
                            {% elseif isListVideoShared %}
                            data-src="{{ path('files_preview', { id: file.id }) }}"
                            data-media-preview-type="video"
                            data-title="{{ file.originalFileName }}"
                            {% elseif isListAudioShared %}
                            data-src="{{ path('files_preview', { id: file.id }) }}"
                            data-media-preview-type="audio"
                            data-title="{{ file.originalFileName }}"
                            {% elseif isListTextShared %}
                            data-src="{{ path('files_preview', { id: file.id }) }}"
                            data-media-preview-type="text"
                            data-title="{{ file.originalFileName }}"
                            {% endif %}
                            tabindex="0"
                            role="button"
                            aria-label="{{ 'files.action.preview'|trans({}, 'messages', currentLocale) }}: {{ file.originalFileName }}"
                            {% endif %}
                        >{{ file.originalFileName }}</td>
                        <td class="text-start text-nowrap" data-files-col="owner-pseudo" title="{{ ownerLabelsByFileId[file.id]|default('-') }}">{{ ownerLabelsByFileId[file.id]|default('-') }}</td>
                        <td class="files-row-clickable text-end text-nowrap" data-files-col="size" data-files-row-target="{{ file.id }}">{{ file.byteSize|files_size_format }}</td>
                        <td class="files-actions-anchor-cell">{% include 'files/_file_actions_dropdown_shared_for_me.html.twig' with { file: file } %}</td>
                    </tr>
                {% else %}
                    {% if sharedForMeFolders is empty %}
                        <tr>
                            <td colspan="6" class="text-muted">{{ (listingScope|default('both') == 'shared' ? 'files.listing_scope.empty_shared' : 'files.section.shared_for_me_empty')|trans({}, 'messages', currentLocale) }}</td>
                        </tr>
                    {% endif %}
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% include 'files/components/mobile/_mobile_list_shared.html.twig' with {
        sharedForMeFolders: sharedForMeFolders,
        sharedForMeFiles: sharedForMeFiles,
        sharedFolderSizeBytes: sharedFolderSizeBytes,
        ownerLabelsByFolderId: ownerLabelsByFolderId|default({}),
        ownerLabelsByFileId: ownerLabelsByFileId|default({}),
        listingQuery: listingQuery,
        filesIndexRoute: filesIndexRoute|default('files_index'),
        folderCursorKey: 'shared_folder',
        selectAllId: 'files-select-all-mobile-shared',
        currentSortField: currentSortField,
        sortCycle: sortCycle,
        listingScope: listingScope|default('both'),
        currentLocale: currentLocale
    } %}
{% endif %}
            </div>
        </div>
    </div>
    {% endif %}
</div>
<p class="visually-hidden" id="files-selection-live" aria-live="polite" data-files-selection-live data-msg-selection-count="{{ 'files.selection.live_count'|trans({ '%count%': '%count%' }, 'messages', currentLocale) }}"></p>
