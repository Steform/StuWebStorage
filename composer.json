{
  "type": "project",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "ext-ctype": "*",
    "ext-gd": "*",
    "ext-iconv": "*",
    "doctrine/dbal": "^4.0",
    "doctrine/doctrine-bundle": "^3.2",
    "doctrine/doctrine-migrations-bundle": "^4.0",
    "doctrine/orm": "^3.3",
    "symfony/asset": "8.1.*",
    "symfony/console": "8.1.*",
    "symfony/dotenv": "8.1.*",
    "symfony/flex": "^2.5",
    "symfony/framework-bundle": "8.1.*",
    "symfony/html-sanitizer": "^8.1",
    "symfony/mailer": "8.1.*",
    "symfony/mime": "8.1.*",
    "symfony/monolog-bundle": "^4.0",
    "symfony/rate-limiter": "8.1.*",
    "symfony/runtime": "8.1.*",
    "symfony/security-bundle": "8.1.*",
    "symfony/translation": "8.1.*",
    "symfony/twig-bundle": "8.1.*",
    "symfony/yaml": "8.1.*"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-doctrine": "^2.0",
    "phpstan/phpstan-symfony": "^2.0",
    "phpunit/phpunit": "^11.5",
    "symfony/browser-kit": "8.1.*",
    "symfony/dom-crawler": "8.1.*",
    "symfony/phpunit-bridge": "8.1.*",
    "symfony/web-profiler-bundle": "8.1.*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "analyse": "phpstan analyse",
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "8.1.*"
    }
  },
  "name": "stuweb/storage"
}
